launcher_refresh_auto_options() {
  local merged=() item
  for item in "${LAUNCHER_CLAUDE_OPTIONS[@]-}" "${LAUNCHER_CODEX_OPTIONS[@]-}"; do
    [ -n "$item" ] || continue
    local seen=false existing
    for existing in "${merged[@]-}"; do
      if [ "$existing" = "$item" ]; then
        seen=true
        break
      fi
    done
    [ "$seen" = true ] || merged+=("$item")
  done
  LAUNCHER_AUTO_OPTIONS=("${merged[@]-}")
}

