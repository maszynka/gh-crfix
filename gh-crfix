SPINNER_IDX=0
TUI_SELECTED=0
TUI_VIEW="dashboard"     # dashboard | detail
TUI_DETAIL_SCROLL=0       # scroll offset in detail view
TUI_READY_LIST=""          # cached ready PR list
TUI_READY_COUNT=0
LAUNCH_SELECTED=0
LAUNCH_ERROR=""
LAUNCH_TARGET=""
LAUNCH_BACKEND=""
LAUNCH_GATE_MODEL=""
LAUNCH_FIX_MODEL=""
LAUNCH_CONCURRENCY=""
LAUNCH_SCORE_NEEDS_LLM=""
LAUNCH_SCORE_PR_COMMENT=""
LAUNCH_SCORE_TEST_FAILURE=""

# Get status of a PR: queued | running | done | failed
pr_status() {
  local pr_num="$1"
  if [ -f "$LOG_DIR/pr-${pr_num}.status" ]; then
    local s
    s="$(cat "$LOG_DIR/pr-${pr_num}.status")"
    if [ "$s" = "OK" ]; then echo "done"; else echo "failed"; fi
  elif [ -f "$LOG_DIR/pr-${pr_num}.started" ]; then
    echo "running"
  else
    echo "queued"
  fi
}

# Elapsed time formatted as M:SS
pr_elapsed() {
  local pr_num="$1"
  local start_file="$LOG_DIR/pr-${pr_num}.started"
  if [ ! -f "$start_file" ]; then echo "    "; return; fi
  local start now elapsed mins secs
  start="$(cat "$start_file")"
  now="$(date +%s)"
  elapsed=$((now - start))
  mins=$((elapsed / 60))
  secs=$((elapsed % 60))
  printf '%d:%02d' "$mins" "$secs"
}

# Get N-th PR number from ready list (0-indexed)
pr_at_index() {
  local idx="$1" i=0
  for pr in $TUI_READY_LIST; do
    if [ "$i" -eq "$idx" ]; then echo "$pr"; return; fi
    i=$((i + 1))
  done
}

# ── TUI: terminal input ─────────────────────────────────────────────────────
# Open a dedicated fd (4) for the terminal to avoid stdin conflicts
tui_open_tty() {
  exec 4</dev/tty
  stty -echo -icanon min 0 time 0 </dev/tty 2>/dev/null || true
}
tui_close_tty() {
  stty echo icanon </dev/tty 2>/dev/null || true
  exec 4<&- 2>/dev/null || true
}

# Read one keypress (non-blocking, ~0.4s timeout via loop)
tui_read_key() {
  local key=""
  local status=0
  # Use the dedicated tty fd
  IFS= read -rsn1 -t 1 key <&4 2>/dev/null
  status=$?

  if [ "$status" -ne 0 ]; then
    # Timeout — no input
    echo ""
    return
  fi

  if [ -z "$key" ]; then
    echo "ENTER"
    return
  fi

  # ESC character (decimal 27)
  local esc_char
  esc_char="$(printf '\033')"

  if [ "$key" = "$esc_char" ]; then
    # Read rest of escape sequence — arrow keys send ESC [ A/B/C/D
    local c1="" c2="" c3=""
    IFS= read -rsn1 -t 1 c1 <&4 2>/dev/null || true
    IFS= read -rsn1 -t 1 c2 <&4 2>/dev/null || true
    if [ "${c1}${c2}" = "[3" ]; then
      IFS= read -rsn1 -t 1 c3 <&4 2>/dev/null || true
    fi
    case "${c1}${c2}${c3}" in
      '[A') echo "UP" ;;
      '[B') echo "DOWN" ;;
      '[C') echo "RIGHT" ;;
      '[D') echo "LEFT" ;;
      '[3~') echo "DELETE" ;;
      *)    echo "ESC" ;;
    esac
  elif [ "$key" = $'\177' ] || [ "$key" = $'\010' ]; then
    echo "BACKSPACE"
  elif [ "$key" = $'\t' ]; then
    echo "TAB"
  elif [ "$key" = "q" ] || [ "$key" = "Q" ]; then
    echo "QUIT"
  else
    echo "$key"
  fi
}

# ANSI escape helpers — inline codes for buffered rendering (no tput calls)
RST=$'\033[0m'
BOLD=$'\033[1m'
CLR=$'\033[K'       # clear to end of line
c_yellow=$'\033[33m'
c_green=$'\033[32m'
c_red=$'\033[31m'
c_gray=$'\033[90m'
c_white=$'\033[37m'

spinner_char() {
  local simple_frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local idx=$((SPINNER_IDX % 10))
  echo "${simple_frames[$idx]}"
}

launcher_reset() {
  LAUNCH_SELECTED=0
  LAUNCH_ERROR=""
  LAUNCH_TARGET=""
  LAUNCH_BACKEND="$AI_BACKEND"
  LAUNCH_GATE_MODEL="$GATE_MODEL"
  LAUNCH_FIX_MODEL="$FIX_MODEL"
  LAUNCH_CONCURRENCY="$CONCURRENCY"
  LAUNCH_SCORE_NEEDS_LLM="$SCORE_NEEDS_LLM"
  LAUNCH_SCORE_PR_COMMENT="$SCORE_PR_COMMENT"
  LAUNCH_SCORE_TEST_FAILURE="$SCORE_TEST_FAILURE"
}

launcher_field_count() { echo 9; }

launcher_field_label() {
  case "$1" in
    0) echo "Target" ;;
    1) echo "AI backend" ;;
    2) echo "Gate model" ;;
    3) echo "Fix model" ;;
    4) echo "Concurrency" ;;
    5) echo "Score: needs_llm" ;;
    6) echo "Score: pr_comment" ;;
    7) echo "Score: test_failure" ;;
    8) echo "Start" ;;
  esac
}

launcher_field_value() {
  case "$1" in
    0) echo "$LAUNCH_TARGET" ;;
    1) echo "$LAUNCH_BACKEND" ;;
    2) echo "$LAUNCH_GATE_MODEL" ;;
    3) echo "$LAUNCH_FIX_MODEL" ;;
    4) echo "$LAUNCH_CONCURRENCY" ;;
    5) echo "$LAUNCH_SCORE_NEEDS_LLM" ;;
    6) echo "$LAUNCH_SCORE_PR_COMMENT" ;;
    7) echo "$LAUNCH_SCORE_TEST_FAILURE" ;;
    8) echo "Press Enter to launch" ;;
  esac
}

launcher_set_value() {
  local idx="$1" value="$2"
  case "$idx" in
    0) LAUNCH_TARGET="$value" ;;
    1) LAUNCH_BACKEND="$value" ;;
    2) LAUNCH_GATE_MODEL="$value" ;;
    3) LAUNCH_FIX_MODEL="$value" ;;
    4) LAUNCH_CONCURRENCY="$value" ;;
    5) LAUNCH_SCORE_NEEDS_LLM="$value" ;;
    6) LAUNCH_SCORE_PR_COMMENT="$value" ;;
    7) LAUNCH_SCORE_TEST_FAILURE="$value" ;;
  esac
}

launcher_append_char() {
  local idx="$1" char="$2"
  case "$idx" in
    0|2|3|4|5|6|7)
      launcher_set_value "$idx" "$(launcher_field_value "$idx")$char"
      ;;
  esac
}

launcher_backspace() {
  local idx="$1" current
  current="$(launcher_field_value "$idx")"
  [ -n "$current" ] || return 0
  launcher_set_value "$idx" "${current%?}"
}

launcher_cycle_backend() {
  case "$LAUNCH_BACKEND" in
    auto)   LAUNCH_BACKEND="$([ "$1" = "right" ] && echo claude || echo codex)" ;;
    claude) LAUNCH_BACKEND="$([ "$1" = "right" ] && echo codex || echo auto)" ;;
    codex)  LAUNCH_BACKEND="$([ "$1" = "right" ] && echo auto || echo claude)" ;;
    *)      LAUNCH_BACKEND="auto" ;;
  esac
}

launcher_render() {
  local cols rows
  cols=$(tput cols 2>/dev/null || echo 80)
  rows=$(tput lines 2>/dev/null || echo 24)

  local buf=""
  buf="${buf}\033[H"
  buf="${buf}  ${BOLD}gh crfix launcher${RST}${CLR}\n"
  buf="${buf}  ${c_gray}Wpisz numer PR, zakres, listę albo pełny URL. Ustaw modele i scoring; gate odpali się od progu 1.0.${RST}${CLR}\n\n"

  local idx=0 count label value prefix
  count="$(launcher_field_count)"
  while [ "$idx" -lt "$count" ]; do
    label="$(launcher_field_label "$idx")"
    value="$(launcher_field_value "$idx")"
    [ -z "$value" ] && value=" "
    if [ ${#value} -gt "$((cols - 26))" ]; then
      value="${value:0:$((cols - 27))}…"
    fi
    if [ "$idx" -eq "$LAUNCH_SELECTED" ]; then
      prefix="${BOLD}▸${RST}"
      buf="${buf} ${prefix} ${BOLD}$(printf '%-20s' "$label")${RST} ${c_white}${value}${RST}${CLR}\n"
    else
      buf="${buf}   $(printf '%-20s' "$label") ${c_gray}${value}${RST}${CLR}\n"
    fi
    idx=$((idx + 1))
  done

  buf="${buf}\n"
  buf="${buf}  ${c_gray}↑↓/Tab navigate  ←→ backend  type to edit  Backspace delete  Enter launch${RST}${CLR}\n"
  if [ -n "$LAUNCH_ERROR" ]; then
    buf="${buf}  ${c_red}${LAUNCH_ERROR}${RST}${CLR}\n"
  fi

  buf="${buf}\033[$((rows));1H"
  buf="${buf}  ${c_gray}q / Esc cancel${RST}${CLR}"
  printf '%b' "$buf"
}

launcher_apply() {
  local old_owner="$OWNER_REPO" old_prs="$PR_NUMBERS"

  [ -n "$LAUNCH_TARGET" ] || { LAUNCH_ERROR="Target is required."; return 1; }
  case "$LAUNCH_BACKEND" in auto|claude|codex) ;; *) LAUNCH_ERROR="AI backend must be auto, claude or codex."; return 1 ;; esac
  case "$LAUNCH_CONCURRENCY" in ''|*[!0-9]*) LAUNCH_ERROR="Concurrency must be an integer."; return 1 ;; esac
  [ "$LAUNCH_CONCURRENCY" -ge 1 ] || { LAUNCH_ERROR="Concurrency must be >= 1."; return 1; }
  is_number_0_to_1 "$LAUNCH_SCORE_NEEDS_LLM" || { LAUNCH_ERROR="Score needs_llm must be between 0 and 1."; return 1; }
  is_number_0_to_1 "$LAUNCH_SCORE_PR_COMMENT" || { LAUNCH_ERROR="Score pr_comment must be between 0 and 1."; return 1; }
  is_number_0_to_1 "$LAUNCH_SCORE_TEST_FAILURE" || { LAUNCH_ERROR="Score test_failure must be between 0 and 1."; return 1; }

  if ! (parse_input "$LAUNCH_TARGET") >/dev/null 2>&1; then
    OWNER_REPO="$old_owner"
    PR_NUMBERS="$old_prs"
    LAUNCH_ERROR="Target could not be parsed. Use PR number, range, list or GitHub URL."
    return 1
  fi

  AI_BACKEND="$LAUNCH_BACKEND"
  GATE_MODEL="$LAUNCH_GATE_MODEL"
  FIX_MODEL="$LAUNCH_FIX_MODEL"
  CONCURRENCY="$LAUNCH_CONCURRENCY"
  SCORE_NEEDS_LLM="$(normalize_score "$LAUNCH_SCORE_NEEDS_LLM")"
  SCORE_PR_COMMENT="$(normalize_score "$LAUNCH_SCORE_PR_COMMENT")"
  SCORE_TEST_FAILURE="$(normalize_score "$LAUNCH_SCORE_TEST_FAILURE")"
  parse_input "$LAUNCH_TARGET"
  LAUNCH_FROM_TUI=true
  return 0
}

launcher_loop() {
  launcher_reset
  TUI_ACTIVE=true
  tui_open_tty
  tput smcup
  tput civis
  tput clear

  while true; do
    launcher_render
    local key
    key="$(tui_read_key)"

    case "$key" in
      UP)
        LAUNCH_SELECTED=$((LAUNCH_SELECTED - 1))
        [ "$LAUNCH_SELECTED" -lt 0 ] && LAUNCH_SELECTED=8
        ;;
      DOWN|TAB|ENTER)
        if [ "$key" = "ENTER" ] && [ "$LAUNCH_SELECTED" -eq 8 ]; then
          if launcher_apply; then
            break
          fi
        else
          LAUNCH_SELECTED=$((LAUNCH_SELECTED + 1))
          [ "$LAUNCH_SELECTED" -gt 8 ] && LAUNCH_SELECTED=0
        fi
        ;;
      LEFT)
        [ "$LAUNCH_SELECTED" -eq 1 ] && launcher_cycle_backend "left"
        ;;
      RIGHT)
        [ "$LAUNCH_SELECTED" -eq 1 ] && launcher_cycle_backend "right"
        ;;
      BACKSPACE|DELETE)
        launcher_backspace "$LAUNCH_SELECTED"
        ;;
      QUIT|ESC)
        tui_close_tty
        tput cnorm
        tput rmcup
        TUI_ACTIVE=false
        return 1
        ;;
      "")
        ;;
      *)
        LAUNCH_ERROR=""
        launcher_append_char "$LAUNCH_SELECTED" "$key"
        ;;
    esac
  done

  tui_close_tty
  tput cnorm
  tput rmcup
  TUI_ACTIVE=false
}

# ── TUI: render dashboard (buffered — single write) ─────────────────────────

tui_render_dashboard() {
  local cols rows
  cols=$(tput cols 2>/dev/null || echo 80)
  rows=$(tput lines 2>/dev/null || echo 24)

  local buf=""
  buf="${buf}\033[H"  # cursor home

  # Count states
  local n_running=0 n_done=0 n_failed=0 n_queued=0
  for pr in $TUI_READY_LIST; do
    case "$(pr_status "$pr")" in
      running) n_running=$((n_running + 1)) ;;
      done)    n_done=$((n_done + 1)) ;;
      failed)  n_failed=$((n_failed + 1)) ;;
      queued)  n_queued=$((n_queued + 1)) ;;
    esac
  done

  # Header
  local spin
  spin="$(spinner_char)"
  buf="${buf}  ${BOLD}gh crfix${RST}  │  "
  [ "$n_running" -gt 0 ] && buf="${buf}${c_yellow}${spin} ${n_running} running${RST}  "
  [ "$n_done" -gt 0 ]    && buf="${buf}${c_green}✓ ${n_done} done${RST}  "
  [ "$n_failed" -gt 0 ]  && buf="${buf}${c_red}✗ ${n_failed} failed${RST}  "
  [ "$n_queued" -gt 0 ]  && buf="${buf}${c_gray}◌ ${n_queued} queued${RST}  "
  buf="${buf}${CLR}\n"

  # Separator
  local sep=""
  local si=0
  while [ "$si" -lt "$cols" ]; do sep="${sep}─"; si=$((si + 1)); done
  buf="${buf}${c_gray}${sep}${RST}\n"

  # PR list
  local idx=0
  local title_max=$((cols - 38))
  [ "$title_max" -lt 10 ] && title_max=10
  local row_count=2  # header + separator

  for pr in $TUI_READY_LIST; do
    local status elapsed title tc icon color_code
    status="$(pr_status "$pr")"
    elapsed="$(pr_elapsed "$pr")"
    title="$(kv_get "$pr" title)"
    tc="$(kv_get "$pr" thread_count)"

    if [ ${#title} -gt "$title_max" ]; then
      title="${title:0:$((title_max - 1))}…"
    fi

    case "$status" in
      running) icon="$spin"; color_code="$c_yellow" ;;
      done)    icon="✓";     color_code="$c_green" ;;
      failed)  icon="✗";     color_code="$c_red" ;;
      queued)  icon="◌";     color_code="$c_gray" ;;
    esac

    if [ "$idx" -eq "$TUI_SELECTED" ]; then
      buf="${buf} ${BOLD}▸ ${color_code}${icon}${RST} ${BOLD}#${pr}${RST}"
    else
      buf="${buf}   ${color_code}${icon}${RST}  #${pr}"
    fi

    # Pad PR number
    local pr_len=${#pr}
    local pad_needed=$((4 - pr_len))
    local pi=0
    while [ "$pi" -lt "$pad_needed" ]; do buf="${buf} "; pi=$((pi + 1)); done

    buf="${buf}  $(printf '%5s' "$elapsed")  $(printf '%2s' "$tc") threads  "
    buf="${buf}${color_code}${title}${RST}${CLR}\n"

    idx=$((idx + 1))
    row_count=$((row_count + 1))
  done

  buf="${buf}\n"
  row_count=$((row_count + 1))

  # Preview separator
  local sel_pr
  sel_pr="$(pr_at_index "$TUI_SELECTED")"
  local preview_hdr=" ─── #${sel_pr} preview "
  local hdr_len=${#preview_hdr}
  local rest=""
  local ri="$hdr_len"
  while [ "$ri" -lt "$cols" ]; do rest="${rest}─"; ri=$((ri + 1)); done
  buf="${buf}${c_gray}${preview_hdr}${rest}${RST}\n"
  row_count=$((row_count + 1))

  # Preview: last N lines
  local preview_rows=$((rows - row_count - 2))
  [ "$preview_rows" -lt 3 ] && preview_rows=3
  local log_file="$LOG_DIR/pr-${sel_pr}.log"

  if [ -f "$log_file" ]; then
    local preview_content
    preview_content="$(tail -"$preview_rows" "$log_file" 2>/dev/null)"
    local lc=0
    while IFS= read -r line; do
      if [ ${#line} -gt "$((cols - 4))" ]; then
        line="${line:0:$((cols - 5))}…"
      fi
      buf="${buf}  ${c_white}${line}${RST}${CLR}\n"
      lc=$((lc + 1))
    done <<EOF
$preview_content
EOF
    # Fill remaining preview rows
    while [ "$lc" -lt "$preview_rows" ]; do
      buf="${buf}${CLR}\n"
      lc=$((lc + 1))
    done
  else
    buf="${buf}  ${c_gray}(waiting...)${RST}${CLR}\n"
    local lc=1
    while [ "$lc" -lt "$preview_rows" ]; do
      buf="${buf}${CLR}\n"
      lc=$((lc + 1))
    done
  fi

  # Footer (position at last row)
  buf="${buf}\033[$((rows));1H"
  buf="${buf}  ${c_gray}↑↓ navigate  ⏎ full log  q quit${RST}${CLR}"

  # Single write
  printf '%b' "$buf"
}

# ── TUI: render detail view (buffered — single write) ────────────────────────

tui_render_detail() {
  local cols rows
  cols=$(tput cols 2>/dev/null || echo 80)
  rows=$(tput lines 2>/dev/null || echo 24)

  local sel_pr
  sel_pr="$(pr_at_index "$TUI_SELECTED")"
  local title="$(kv_get "$sel_pr" title)"
  local status="$(pr_status "$sel_pr")"
  local elapsed="$(pr_elapsed "$sel_pr")"

  local buf=""
  buf="${buf}\033[H"  # cursor home

  local status_icon status_color
  case "$status" in
    running) status_icon="$(spinner_char)"; status_color="$c_yellow" ;;
    done)    status_icon="✓"; status_color="$c_green" ;;
    failed)  status_icon="✗"; status_color="$c_red" ;;
    queued)  status_icon="◌"; status_color="$c_gray" ;;
  esac

  # Header
  buf="${buf}  ${BOLD}PR #${sel_pr}${RST} — ${title}  "
  buf="${buf}${status_color}[${status_icon} ${status} ${elapsed}]${RST}${CLR}\n"

  # Separator
  local sep=""
  local si=0
  while [ "$si" -lt "$cols" ]; do sep="${sep}─"; si=$((si + 1)); done
  buf="${buf}${c_gray}${sep}${RST}\n"

  # Log content
  local content_rows=$((rows - 4))
  local log_file="$LOG_DIR/pr-${sel_pr}.log"
  local total_lines=0

  if [ -f "$log_file" ]; then
    total_lines=$(wc -l < "$log_file" | tr -d ' ')
  fi

  local max_scroll=$((total_lines - content_rows))
  [ "$max_scroll" -lt 0 ] && max_scroll=0

  if [ "$TUI_DETAIL_SCROLL" -ge "$((max_scroll - 2))" ] || [ "$TUI_DETAIL_SCROLL" -eq -1 ]; then
    TUI_DETAIL_SCROLL=$max_scroll
  fi

  local skip="$TUI_DETAIL_SCROLL"
  [ "$skip" -lt 0 ] && skip=0

  local displayed=0
  if [ -f "$log_file" ]; then
    local line_num=0
    while IFS= read -r line; do
      line_num=$((line_num + 1))
      if [ "$line_num" -le "$skip" ]; then continue; fi
      if [ "$displayed" -ge "$content_rows" ]; then break; fi

      if [ ${#line} -gt "$((cols - 2))" ]; then
        line="${line:0:$((cols - 3))}…"
      fi

      buf="${buf} ${line}${CLR}\n"
      displayed=$((displayed + 1))
    done < "$log_file"
  fi

  while [ "$displayed" -lt "$content_rows" ]; do
    buf="${buf}${CLR}\n"
    displayed=$((displayed + 1))
  done

  # Footer
  buf="${buf}\033[$((rows));1H"
  buf="${buf}  ${c_gray}↑↓ scroll  Esc/q back  "
  if [ "$total_lines" -gt 0 ]; then
    local pct=$(( (skip + content_rows) * 100 / (total_lines + 1) ))
    [ "$pct" -gt 100 ] && pct=100
    buf="${buf}[${skip}/${total_lines} lines  ${pct}%%]"
  fi
  buf="${buf}${RST}${CLR}"

  printf '%b' "$buf"
}

# ── TUI: check if all jobs are done ─────────────────────────────────────────

tui_all_done() {
  for pr in $TUI_READY_LIST; do
    local s
    s="$(pr_status "$pr")"
    if [ "$s" = "running" ] || [ "$s" = "queued" ]; then
      return 1
    fi
  done
  return 0
}

# ── TUI: main loop ──────────────────────────────────────────────────────────

tui_loop() {
  TUI_READY_LIST="$1"
  TUI_READY_COUNT=0
  for _ in $TUI_READY_LIST; do TUI_READY_COUNT=$((TUI_READY_COUNT + 1)); done

  # Init terminal
  TUI_ACTIVE=true
  tui_open_tty
  tput smcup    # alternate screen buffer
  tput civis    # hide cursor
  tput clear

  TUI_DETAIL_SCROLL=-1  # -1 = follow tail

  while true; do
    SPINNER_IDX=$((SPINNER_IDX + 1))

    # Render
    if [ "$TUI_VIEW" = "dashboard" ]; then
      tui_render_dashboard
    else
      tui_render_detail
    fi

    # Read input
    local key
    key="$(tui_read_key)"

    case "$TUI_VIEW" in
      dashboard)
        case "$key" in
          UP)
            TUI_SELECTED=$((TUI_SELECTED - 1))
            [ "$TUI_SELECTED" -lt 0 ] && TUI_SELECTED=$((TUI_READY_COUNT - 1))
            ;;
          DOWN)
            TUI_SELECTED=$((TUI_SELECTED + 1))
            [ "$TUI_SELECTED" -ge "$TUI_READY_COUNT" ] && TUI_SELECTED=0
            ;;
          ENTER)
            TUI_VIEW="detail"
            TUI_DETAIL_SCROLL=-1
            tput clear
            ;;
          QUIT)
            if tui_all_done; then
              break
            fi
            # Show "jobs still running" hint in footer
            ;;
        esac
        ;;
      detail)
        case "$key" in
          UP)
            TUI_DETAIL_SCROLL=$((TUI_DETAIL_SCROLL - 3))
            [ "$TUI_DETAIL_SCROLL" -lt 0 ] && TUI_DETAIL_SCROLL=0
            ;;
          DOWN)
            TUI_DETAIL_SCROLL=$((TUI_DETAIL_SCROLL + 3))
            ;;
          QUIT|ESC)
            TUI_VIEW="dashboard"
            tput clear
            ;;
        esac
        ;;
    esac

    # Auto-exit when all done (after small delay for final render)
    if tui_all_done && [ "$TUI_VIEW" = "dashboard" ]; then
      # One more render to show final state
      SPINNER_IDX=$((SPINNER_IDX + 1))
      tui_render_dashboard
      sleep 1
      break
    fi
  done

  # Cleanup terminal
  TUI_ACTIVE=false
  tui_close_tty
  tput cnorm    # show cursor
  tput rmcup    # restore screen
}

# ── setup phase (sequential) ─────────────────────────────────────────────────

setup_all() {
  local repo_dir="$1"
  local autofix_hook
  local validate_runner
  autofix_hook="$(detect_autofix_hook "$repo_dir")"
  validate_runner="$(detect_validate_runner "$repo_dir")"
  kv_set global autofix_hook "$autofix_hook"
  kv_set global validate_runner "$validate_runner"

  for pr_num in $PR_NUMBERS; do
    echo ""
    echo "━━━ PR #$pr_num ━━━"

    local pr_json
    pr_json=$(gh pr view "$pr_num" --repo "$OWNER_REPO" \
      --json headRefName,title,state,isDraft 2>/dev/null) \
      || { echo "  ⚠ not found — skipping"; kv_append skipped "$pr_num"; continue; }

    local branch title state is_draft
    branch=$(echo "$pr_json" | jq -r '.headRefName')
    title=$(echo "$pr_json" | jq -r '.title')
    state=$(echo "$pr_json" | jq -r '.state')
    is_draft=$(echo "$pr_json" | jq -r '.isDraft')

    local state_label="$state"
    [ "$is_draft" = "true" ] && state_label="DRAFT"

    echo "  Title : $title"
    echo "  Branch: $branch"
    echo "  State : $state_label"

    kv_set "$pr_num" title "$title"
    kv_set "$pr_num" branch "$branch"

    if [ "$state" != "OPEN" ]; then
      echo "  ⚠ PR is $state — skipping"
      kv_append skipped "$pr_num"
      continue
    fi

    local worktree_path
    worktree_path="$(setup_worktree "$pr_num" "$repo_dir" "$branch")"
    kv_set "$pr_num" worktree "$worktree_path"

    local log_file="$LOG_DIR/pr-$pr_num.log"
    : > "$log_file"

    if [ "$SETUP_ONLY" = true ]; then
      echo "  → cd $worktree_path"
      kv_append skipped "$pr_num"
      continue
    fi

    # Merge base branch before fixing (resolve conflicts first)
    merge_base_branch "$pr_num" "$worktree_path" "$log_file" || true

    echo "  Fetching unresolved threads..."
    local threads_json threads_file triage_file thread_count residual_count
    threads_json="$(get_unresolved_threads "$OWNER_REPO" "$pr_num")"
    thread_count="$(echo "$threads_json" | jq 'length')"
    threads_file="$LOG_DIR/pr-$pr_num-threads.json"
    triage_file="$LOG_DIR/pr-$pr_num-triage.json"

    echo "$threads_json" > "$threads_file"

    if [ "$thread_count" -eq 0 ]; then
      echo "  ✓ No unresolved threads"
      kv_append skipped "$pr_num"
      continue
    fi

    triage_threads "$worktree_path" "$threads_file" "$triage_file"
    residual_count="$(jq '.needs_llm | length' < "$triage_file")"

    kv_set "$pr_num" threads_file "$threads_file"
    kv_set "$pr_num" triage_file "$triage_file"
    kv_set "$pr_num" thread_count "$thread_count"
    kv_set "$pr_num" residual_count "$residual_count"

    echo "  Threads total      : $thread_count"
    echo "  deterministic skip : $(jq '.skip | length' < "$triage_file")"
    echo "  auto/mechanical    : $(jq '.auto | length' < "$triage_file")"
    echo "  already-likely-fix : $(jq '.already_likely_fixed | length' < "$triage_file")"
    echo "  residual needs llm : $residual_count"

    kv_append ready "$pr_num"
  done
}

# ── process_pr (parallel mode — writes to log_file) ─────────────────────────

process_pr() {
  local pr_num="$1"
  local title worktree_path threads_file triage_file log_file hook validate_runner
  title="$(kv_get "$pr_num" title)"
  worktree_path="$(kv_get "$pr_num" worktree)"
  threads_file="$(kv_get "$pr_num" threads_file)"
  triage_file="$(kv_get "$pr_num" triage_file)"
  hook="$(kv_get global autofix_hook)"
  validate_runner="$(kv_get global validate_runner)"
  log_file="$LOG_DIR/pr-$pr_num.log"

  # Signal start
  date +%s > "$LOG_DIR/pr-${pr_num}.started"

  {
    echo "━━━ PR #$pr_num ━━━ [$title]"
    echo "worktree: $worktree_path"
    echo "gate model: $GATE_MODEL"
    echo "fix model : $FIX_MODEL"
    echo ""

    # 1. Write deterministic responses
    local deterministic_responses="$LOG_DIR/pr-$pr_num-deterministic-responses.json"
    write_deterministic_responses "$triage_file" "$deterministic_responses"

    # 2. Run deterministic pre-gate phase
    run_pre_gate_phase "$pr_num" "$worktree_path" "$triage_file" "$hook" "$validate_runner" "$log_file"
    local validation_file="$LOG_DIR/pr-$pr_num-validation.json"
    local gate_context="$LOG_DIR/pr-$pr_num-gate-context.json"

    # 3. Run gate model only after score threshold is met
    local gate_out="$LOG_DIR/pr-$pr_num-gate.json"
    local selected_file="$LOG_DIR/pr-$pr_num-selected.txt"
    local should_run_gate
    should_run_gate="$(jq -r '.should_run_gate // false' < "$gate_context" 2>/dev/null || echo false)"
    : > "$selected_file"

    if [ "$should_run_gate" = "true" ]; then
      run_gate_model "$OWNER_REPO" "$pr_num" "$triage_file" "$validation_file" "$gate_context" "$gate_out" "$log_file"
      jq -r '.threads_to_fix[]?' < "$gate_out" > "$selected_file" || true
    else
      local total_score
      total_score="$(jq -r '.total_score // 0' < "$gate_context" 2>/dev/null || echo 0)"
      jq -n \
        --arg reason "deterministic score below threshold ($total_score < 1)" \
        '{needs_advanced_model: false, reason: $reason, threads_to_fix: []}' > "$gate_out"
      echo "[gate] skipped: $(jq -r '.reason' < "$gate_out")"
    fi

    local needs_advanced
    needs_advanced="$(jq -r '.needs_advanced_model' < "$gate_out" 2>/dev/null || echo "true")"

    # 4. If gate says yes -> run fix model
    if [ "$needs_advanced" = "true" ]; then
      if [ ! -s "$selected_file" ] && [ "$(jq '.needs_llm | length' < "$triage_file")" -gt 0 ]; then
        jq -r '.needs_llm[]?.thread_id' < "$triage_file" > "$selected_file"
      fi

      if [ "$DRY_RUN" = true ]; then
        echo "[dry-run] would run advanced model on:"
        if [ -s "$selected_file" ]; then
          cat "$selected_file"
        else
          echo "(no explicit thread selection; deterministic validation failed)"
        fi
      else
        run_fix_model "$OWNER_REPO" "$pr_num" "$worktree_path" "$threads_file" "$selected_file" "$validation_file" "$log_file"
      fi
    else
      local reason
      reason="$(jq -r '.reason // "n/a"' < "$gate_out" 2>/dev/null)"
      echo "[gate] advanced model not needed ($reason)"

      if [ "$should_run_gate" = "true" ]; then
        # Generate "skipped by gate" responses so needs_llm threads still get resolved
        local gate_skipped="$LOG_DIR/pr-$pr_num-gate-skipped.json"
        jq '[.needs_llm[]? | {
          thread_id: .thread_id,
          action: "already_fixed",
          comment: ("Reviewed by automation — no code change needed: " + .reason + ".")
        }]' < "$triage_file" > "$gate_skipped"
      fi
    fi

    # 5. Merge deterministic + LLM + gate-skipped responses
    local combined="$LOG_DIR/pr-$pr_num-thread-responses.json"
    local model_responses="$worktree_path/thread-responses.json"
    local gate_skipped="$LOG_DIR/pr-$pr_num-gate-skipped.json"
    local resp_files=("$deterministic_responses")
    [ -f "$model_responses" ] && jq -e '.' "$model_responses" >/dev/null 2>&1 && resp_files+=("$model_responses")
    [ -f "$gate_skipped" ] && jq -e '.' "$gate_skipped" >/dev/null 2>&1 && resp_files+=("$gate_skipped")

    if [ "${#resp_files[@]}" -eq 1 ]; then
      cp "${resp_files[0]}" "$combined"
    else
      jq -s 'add' "${resp_files[@]}" > "$combined"
    fi

    local uncovered="$LOG_DIR/pr-$pr_num-uncovered-responses.json"
    write_uncovered_responses "$triage_file" "$selected_file" "$combined" "$uncovered"
    if jq -e 'length > 0' "$uncovered" >/dev/null 2>&1; then
      jq -s 'add' "$combined" "$uncovered" > "$combined.tmp"
      mv "$combined.tmp" "$combined"
    fi

    # 6. Reply and resolve
    if [ "$NO_RESOLVE" = false ]; then
      echo "[resolve] replying/resolving"
      echo "[resolve] $(reply_and_resolve_from_responses "$combined")"
    else
      echo "[resolve] skipped by flag"
    fi

    # 7. Remove thread-responses.json from git (prevents future merge conflicts)
    if [ -f "$worktree_path/thread-responses.json" ]; then
      git -C "$worktree_path" rm -f thread-responses.json >/dev/null 2>&1 || rm -f "$worktree_path/thread-responses.json"
      git -C "$worktree_path" commit -q -m "chore: remove thread-responses.json artifact" 2>/dev/null || true
      git -C "$worktree_path" push -q 2>/dev/null || true
      echo "[cleanup] removed thread-responses.json from git"
    fi

    # 8. Post-fix summary
    post_fix_summary "$pr_num" "$triage_file" "$combined" "$log_file"

    # 9. Request Copilot re-review
    if [ "$DRY_RUN" = false ]; then
      echo "[review] requesting Copilot re-review"
      request_copilot_review "$pr_num"
    fi

    # 10. Post-fix review cycle
    local fixed_count
    fixed_count="$(jq '[.[] | select(.action == "fixed" or .action == "already_fixed")] | length' < "$combined" 2>/dev/null || echo "0")"
    post_fix_review_cycle "$pr_num" "$worktree_path" "$fixed_count" "$log_file"

    # 11. Write status
    echo "[done]"
    echo "OK" > "$LOG_DIR/pr-$pr_num.status"
  } >> "$log_file" 2>&1 || {
    echo "FAIL" > "$LOG_DIR/pr-$pr_num.status"
    return 0
  }
}

# ── process_pr_sequential — same as process_pr but streams to stdout ─────────

process_pr_sequential() {
  local pr_num="$1"
  local title worktree_path threads_file triage_file log_file hook validate_runner
  title="$(kv_get "$pr_num" title)"
  worktree_path="$(kv_get "$pr_num" worktree)"
  threads_file="$(kv_get "$pr_num" threads_file)"
  triage_file="$(kv_get "$pr_num" triage_file)"
  hook="$(kv_get global autofix_hook)"
  validate_runner="$(kv_get global validate_runner)"
  log_file="$LOG_DIR/pr-$pr_num.log"

  date +%s > "$LOG_DIR/pr-${pr_num}.started"

  echo ""
  echo "━━━ PR #$pr_num ━━━  [$title]"
  echo "  Worktree  : $worktree_path"
  echo "  Gate model: $GATE_MODEL"
  echo "  Fix model : $FIX_MODEL"
  echo ""

  # 1. Write deterministic responses
  local deterministic_responses="$LOG_DIR/pr-$pr_num-deterministic-responses.json"
  write_deterministic_responses "$triage_file" "$deterministic_responses"
  echo "  deterministic responses written"

  # 2. Run deterministic pre-gate phase
  echo "  Running deterministic validation..."
  run_pre_gate_phase "$pr_num" "$worktree_path" "$triage_file" "$hook" "$validate_runner" "$log_file"
  local validation_file="$LOG_DIR/pr-$pr_num-validation.json"
  local gate_context="$LOG_DIR/pr-$pr_num-gate-context.json"
  echo "  Validation : $(jq -r '.summary' < "$validation_file")"
  echo "  Gate score : $(jq -r '.total_score' < "$gate_context")"

  # 3. Run gate model only after score threshold is met
  local gate_out="$LOG_DIR/pr-$pr_num-gate.json"
  local selected_file="$LOG_DIR/pr-$pr_num-selected.txt"
  local should_run_gate
  should_run_gate="$(jq -r '.should_run_gate // false' < "$gate_context" 2>/dev/null || echo false)"
  : > "$selected_file"

  if [ "$should_run_gate" = "true" ]; then
    echo "  Running gate model ($GATE_MODEL)..."
    run_gate_model "$OWNER_REPO" "$pr_num" "$triage_file" "$validation_file" "$gate_context" "$gate_out" "$log_file"
    jq -r '.threads_to_fix[]?' < "$gate_out" > "$selected_file" || true
  else
    local total_score
    total_score="$(jq -r '.total_score // 0' < "$gate_context" 2>/dev/null || echo 0)"
    jq -n \
      --arg reason "deterministic score below threshold ($total_score < 1)" \
      '{needs_advanced_model: false, reason: $reason, threads_to_fix: []}' > "$gate_out"
    echo "  Gate: SKIP — $(jq -r '.reason' < "$gate_out")"
  fi

  local needs_advanced
  needs_advanced="$(jq -r '.needs_advanced_model' < "$gate_out" 2>/dev/null || echo "true")"

  # 4. If gate says yes -> run fix model
  if [ "$needs_advanced" = "true" ]; then
    if [ ! -s "$selected_file" ] && [ "$(jq '.needs_llm | length' < "$triage_file")" -gt 0 ]; then
      jq -r '.needs_llm[]?.thread_id' < "$triage_file" > "$selected_file"
    fi

    local sel_count
    sel_count="$(wc -l < "$selected_file" | tr -d ' ')"
    echo "  Gate: YES — $sel_count thread(s) selected; validation_failed=$(jq -r '.tests_failed' < "$validation_file")"

    if [ "$DRY_RUN" = true ]; then
      echo "  [dry-run] would run advanced model on:"
      if [ -s "$selected_file" ]; then
        sed 's/^/    /' "$selected_file"
      else
        echo "    (no explicit thread selection; deterministic validation failed)"
      fi
    else
      echo "  Launching fix model ($FIX_MODEL)..."
      run_fix_model "$OWNER_REPO" "$pr_num" "$worktree_path" "$threads_file" "$selected_file" "$validation_file" "$log_file" \
        || echo "  Fix model failed (continuing)"
    fi
  else
    local reason
    reason="$(jq -r '.reason // "n/a"' < "$gate_out" 2>/dev/null)"
    echo "  Gate: NO — advanced model not needed ($reason)"

    if [ "$should_run_gate" = "true" ]; then
      # Generate "skipped by gate" responses so needs_llm threads still get resolved
      local gate_skipped="$LOG_DIR/pr-$pr_num-gate-skipped.json"
      jq '[.needs_llm[]? | {
        thread_id: .thread_id,
        action: "already_fixed",
        comment: ("Reviewed by automation — no code change needed: " + .reason + ".")
      }]' < "$triage_file" > "$gate_skipped"
    fi
  fi

  # 5. Merge deterministic + LLM + gate-skipped responses
  local combined="$LOG_DIR/pr-$pr_num-thread-responses.json"
  local model_responses="$worktree_path/thread-responses.json"
  local gate_skipped="$LOG_DIR/pr-$pr_num-gate-skipped.json"
  local resp_files=("$deterministic_responses")
  [ -f "$model_responses" ] && jq -e '.' "$model_responses" >/dev/null 2>&1 && resp_files+=("$model_responses")
  [ -f "$gate_skipped" ] && jq -e '.' "$gate_skipped" >/dev/null 2>&1 && resp_files+=("$gate_skipped")

  if [ "${#resp_files[@]}" -eq 1 ]; then
    cp "${resp_files[0]}" "$combined"
  else
    jq -s 'add' "${resp_files[@]}" > "$combined"
  fi

  local uncovered="$LOG_DIR/pr-$pr_num-uncovered-responses.json"
  write_uncovered_responses "$triage_file" "$selected_file" "$combined" "$uncovered"
  if jq -e 'length > 0' "$uncovered" >/dev/null 2>&1; then
    jq -s 'add' "$combined" "$uncovered" > "$combined.tmp"
    mv "$combined.tmp" "$combined"
  fi

  # 6. Reply and resolve
  if [ "$NO_RESOLVE" = false ]; then
    echo "  Replying & resolving threads..."
    local resolve_result
    resolve_result="$(reply_and_resolve_from_responses "$combined")"
    echo "  $resolve_result"
  else
    echo "  (--no-resolve: skipping thread resolution)"
  fi

  # 7. Remove thread-responses.json from git (prevents future merge conflicts)
  if [ -f "$worktree_path/thread-responses.json" ]; then
    git -C "$worktree_path" rm -f thread-responses.json >/dev/null 2>&1 || rm -f "$worktree_path/thread-responses.json"
    git -C "$worktree_path" commit -q -m "chore: remove thread-responses.json artifact" 2>/dev/null || true
    git -C "$worktree_path" push -q 2>/dev/null || true
    echo "  [cleanup] removed thread-responses.json from git"
  fi

  # 8. Post-fix summary
  post_fix_summary "$pr_num" "$triage_file" "$combined" "$log_file"

  # 9. Request Copilot re-review
  if [ "$DRY_RUN" = false ]; then
    echo "  Requesting Copilot re-review..."
    request_copilot_review "$pr_num"
  fi

  # 10. Post-fix review cycle
  local fixed_count
  fixed_count="$(jq '[.[] | select(.action == "fixed" or .action == "already_fixed")] | length' < "$combined" 2>/dev/null || echo "0")"
  post_fix_review_cycle "$pr_num" "$worktree_path" "$fixed_count" "$log_file"

  # 11. Write status
  echo "  ✓ PR #$pr_num complete"
  echo "OK" > "$LOG_DIR/pr-$pr_num.status"
}

# ── print results ────────────────────────────────────────────────────────────

print_results() {
  local pr_num
  for pr_num in $(kv_list ready); do
    local log_file="$LOG_DIR/pr-$pr_num.log"
    local status title
    status="$(cat "$LOG_DIR/pr-$pr_num.status" 2>/dev/null || echo "FAIL")"
    title="$(kv_get "$pr_num" title)"
    echo ""
    if [ "$status" = "OK" ]; then
      echo "━━━ PR #$pr_num ✓ ━━━ [$title]"
    else
      echo "━━━ PR #$pr_num ⚠ ━━━ [$title]"
    fi
    cat "$log_file" 2>/dev/null || true
  done
}

# ── cleanup ──────────────────────────────────────────────────────────────────

TUI_ACTIVE=false

cleanup() {
  if [ "$TUI_ACTIVE" = true ]; then
    tui_close_tty 2>/dev/null || true
    tput cnorm 2>/dev/null || true
    tput rmcup 2>/dev/null || true
    TUI_ACTIVE=false
  fi
  sem_destroy 2>/dev/null || true
  if [ -n "$LOG_DIR" ] && [ -d "$LOG_DIR" ]; then
    rm -rf "$LOG_DIR"
  fi
}

cleanup_sigint() {
  if [ -n "$BG_PIDS" ]; then
    for pid in $BG_PIDS; do
      kill "$pid" 2>/dev/null || true
      kill -9 "$pid" 2>/dev/null || true
    done
    wait 2>/dev/null || true
  fi
  cleanup
  echo ""
  echo "  Interrupted — killed all running jobs."
  exit 130
}

trap cleanup EXIT
trap cleanup_sigint INT TERM

# ── FIFO semaphore ───────────────────────────────────────────────────────────

sem_init() {
  SEMAPHORE=$(mktemp -u /tmp/gh-crfix-sem.XXXXXX)
  mkfifo "$SEMAPHORE"
  exec 3<>"$SEMAPHORE"
  local i=0
  while [ "$i" -lt "$CONCURRENCY" ]; do printf '\n' >&3; i=$((i + 1)); done
}
sem_acquire() { IFS= read -r -u 3; }
sem_release() { printf '\n' >&3; }
sem_destroy() { exec 3>&- 2>/dev/null || true; rm -f "$SEMAPHORE" 2>/dev/null || true; }

# ── main ─────────────────────────────────────────────────────────────────────

main() {
  if [ "$#" -eq 0 ]; then
    if [ -t 0 ] && [ -t 1 ]; then
      launcher_loop || return 0
    else
      usage
      return 0
    fi
  else
    parse_flags "$@"
  fi

  LOG_DIR="$(mktemp -d /tmp/gh-crfix-XXXXXX)"
  verify_prereqs

  echo "Repo       : $OWNER_REPO"
  local repo_dir
  repo_dir="$(find_local_repo "$OWNER_REPO")"
  echo "Local repo : $repo_dir"
  echo "Concurrency: $CONCURRENCY"
  echo "Gate model : $GATE_MODEL"
  echo "Fix model  : $FIX_MODEL"

  local hook
  hook="$(detect_autofix_hook "$repo_dir")"
  if [ -n "$hook" ]; then
    echo "Autofix    : $hook"
  else
    echo "Autofix    : none"
  fi

  local validate_runner
  validate_runner="$(detect_validate_runner "$repo_dir")"
  if [ -n "$validate_runner" ]; then
    echo "Validate   : ${validate_runner#*::}"
  else
    echo "Validate   : none"
  fi

  [ "$DRY_RUN" = true ] && echo "Mode       : DRY RUN"

  # Phase 1: sequential setup (worktrees, merge, threads, triage)
  setup_all "$repo_dir"

  local total=0 ready=0 skipped=0
  for _ in $PR_NUMBERS; do total=$((total + 1)); done

  local ready_list="$(kv_list ready)"
  for _ in $ready_list; do ready=$((ready + 1)); done
  for _ in $(kv_list skipped); do skipped=$((skipped + 1)); done

  if [ "$ready" -eq 0 ]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Done — $total PR(s), nothing to process."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    return 0
  fi

  resolve_ai_backend
  echo "AI backend : $AI_BACKEND"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  Processing $ready PR(s) with concurrency=$CONCURRENCY"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # Determine if TUI should be used
  local use_tui=false
  if [ "$CONCURRENCY" -gt 1 ] && [ "$NO_TUI" = false ] && [ -t 1 ]; then
    use_tui=true
  fi

  # Phase 2: fix PRs
  if [ "$CONCURRENCY" -eq 1 ]; then
    # Sequential — stream directly to stdout
    for pr_num in $ready_list; do
      process_pr_sequential "$pr_num"
    done
  else
    # Parallel — launch background jobs
    sem_init
    local pids=""

    for pr_num in $ready_list; do
      (
        sem_acquire
        process_pr "$pr_num"
        sem_release
      ) &
      pids="${pids:+$pids }$!"
      BG_PIDS="$pids"
    done

    if [ "$use_tui" = true ]; then
      # TUI monitors jobs
      tui_loop "$ready_list"

      # Wait for any stragglers
      for pid in $pids; do
        wait "$pid" 2>/dev/null || true
      done
      sem_destroy

      # Print final results after TUI exits
      print_results
    else
      # No TUI — just wait
      for pid in $pids; do
        wait "$pid" 2>/dev/null || true
      done
      sem_destroy
      print_results
    fi
  fi

  # Summary
  local ok=0 fail=0
  for pr_num in $ready_list; do
    local s
    s="$(cat "$LOG_DIR/pr-${pr_num}.status" 2>/dev/null || echo "FAIL")"
    if [ "$s" = "OK" ]; then ok=$((ok + 1)); else fail=$((fail + 1)); fi
  done

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  Done — $total PR(s): $ok fixed, $skipped skipped, $fail failed"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # Terminal bell + macOS notification
  printf '\a'
  command -v osascript >/dev/null 2>&1 && \
    osascript -e "display notification \"$ok fixed, $skipped skipped, $fail failed\" with title \"gh crfix done\" sound name \"Glass\"" 2>/dev/null || true
}

# Allow sourcing without executing (for tests)
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
  main "$@"
fi
