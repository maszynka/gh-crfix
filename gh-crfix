# ── reply / resolve ──────────────────────────────────────────────────────────

reply_and_resolve_from_responses() {
  local responses_file="$1"
  local resolved=0 replied=0 skipped=0

  [ -f "$responses_file" ] || return 0
  jq -e '.' "$responses_file" >/dev/null 2>&1 || return 0

  local n i
  n="$(jq 'length' < "$responses_file")"
  i=0
  while [ "$i" -lt "$n" ]; do
    local tid action comment resolve_when_skipped
    tid="$(jq -r ".[$i].thread_id // empty" < "$responses_file")"
    action="$(jq -r ".[$i].action // empty" < "$responses_file")"
    comment="$(jq -r ".[$i].comment // empty" < "$responses_file")"
    resolve_when_skipped="$(jq -r ".[$i].resolve_when_skipped // false" < "$responses_file")"

    [ -n "$tid" ] || { i=$((i + 1)); continue; }

    if [ -n "$comment" ]; then
      reply_to_thread "$tid" "$comment" && replied=$((replied + 1))
    fi

    case "$action" in
      fixed|already_fixed)
        resolve_thread "$tid" && resolved=$((resolved + 1))
        ;;
      skipped)
        if [ "$RESOLVE_SKIPPED" = true ] || [ "$resolve_when_skipped" = true ]; then
          resolve_thread "$tid" && resolved=$((resolved + 1))
        else
          skipped=$((skipped + 1))
        fi
        ;;
      *)
        skipped=$((skipped + 1))
        ;;
    esac

    i=$((i + 1))
  done

  echo "replied=$replied resolved=$resolved unresolved_skipped=$skipped"
}

write_deterministic_responses() {
  local triage_file="$1" out_file="$2"

  jq '
    [
      (.already_likely_fixed[]? | {
        thread_id: .thread_id,
        action: "already_fixed",
        comment: ("Likely already addressed: " + .reason + ".")
      }),
      (.skip[]? | {
        thread_id: .thread_id,
        action: "skipped",
        comment: ("Skipped automatically: " + .reason + "."),
        resolve_when_skipped: (.resolve_when_skipped // false)
      })
    ]
  ' < "$triage_file" > "$out_file"
}

write_uncovered_responses() {
  local triage_file="$1" selected_file="$2" existing_file="$3" out_file="$4"
  local selected_json="$LOG_DIR/selected-ids.json"

  if [ -f "$selected_file" ]; then
    jq -Rsc 'split("\n") | map(select(length > 0))' < "$selected_file" > "$selected_json"
  else
    echo '[]' > "$selected_json"
  fi

  jq -n \
    --slurpfile triage "$triage_file" \
    --slurpfile existing "$existing_file" \
    --slurpfile selected "$selected_json" '
    ($triage[0]) as $triage_doc |
    (($existing[0] // []) | map(.thread_id)) as $covered |
    ($selected[0] // []) as $selected_ids |
    [
      ($triage_doc.auto[]? | .thread_id as $thread_id | select(($covered | index($thread_id)) | not) | {
        thread_id: $thread_id,
        action: "skipped",
        comment: ("Not auto-fixed: " + .reason + ". Leaving unresolved for manual follow-up.")
      }),
      ($triage_doc.needs_llm[]? | .thread_id as $thread_id | select(($covered | index($thread_id)) | not) | {
        thread_id: $thread_id,
        action: "skipped",
        comment: (
          if ($selected_ids | index($thread_id)) then
            "Automation did not apply a code change for this thread. Leaving unresolved for manual follow-up."
          else
            "Automation did not select this thread for automatic code changes. Leaving unresolved for manual follow-up."
          end
        )
      })
    ]
  ' > "$out_file"
}

cleanup_thread_responses_artifact() {
  local pr_num="$1" worktree_path="$2"

  if [ ! -f "$worktree_path/thread-responses.json" ]; then
    progress_set "$pr_num" cleanup skipped "nothing to clean"
    return 0
  fi

  if [ "$DRY_RUN" = true ]; then
    echo "[cleanup] dry-run: would remove thread-responses.json from git"
    progress_set "$pr_num" cleanup skipped "dry-run (artifact present)"
    return 0
  fi

  progress_set "$pr_num" cleanup running "removing tracked artifact"
  git -C "$worktree_path" rm -f thread-responses.json >/dev/null 2>&1 || rm -f "$worktree_path/thread-responses.json"
  git -C "$worktree_path" commit -q -m "chore: remove thread-responses.json artifact" 2>/dev/null || true
  git -C "$worktree_path" push -q 2>/dev/null || true
  echo "[cleanup] removed thread-responses.json from git"
  progress_set "$pr_num" cleanup done "artifact removed"
}

# ── conflict resolution ──────────────────────────────────────────────────────

merge_base_branch() {
  local pr_num="$1" worktree_path="$2" log_file="$3"
  local base_branch merge_not_needed=false
  base_branch=$(gh pr view "$pr_num" --repo "$OWNER_REPO" --json baseRefName -q '.baseRefName' 2>/dev/null || echo "master")
  progress_set "$pr_num" merge_base running "origin/$base_branch"
  progress_set "$pr_num" resolve_conflicts pending ""

  {
    echo "[merge] fetching origin/$base_branch"
    if ! git -C "$worktree_path" fetch origin "+refs/heads/$base_branch:refs/remotes/origin/$base_branch" --quiet 2>&1; then
      echo "[merge] WARNING: fetch failed — will use cached origin/$base_branch"
    fi
    git -C "$worktree_path" merge-base --is-ancestor "origin/$base_branch" HEAD >/dev/null 2>&1 && merge_not_needed=true
    echo "[merge] merging origin/$base_branch"
    if git -C "$worktree_path" merge "origin/$base_branch" --no-edit -q 2>/dev/null; then
      if [ "$DRY_RUN" = true ]; then
        echo "[merge] clean"
        echo "[merge] dry-run: not pushing"
        if [ "$merge_not_needed" = true ]; then
          progress_set "$pr_num" merge_base done "merge not needed - branch up to date"
        else
          progress_set "$pr_num" merge_base done "dry-run - merged origin/$base_branch locally"
        fi
        progress_set "$pr_num" resolve_conflicts skipped "not needed"
        return 0
      fi

      if git -C "$worktree_path" push --quiet 2>/dev/null; then
        echo "[merge] clean"
        echo "[merge] pushed"
        if [ "$merge_not_needed" = true ]; then
          progress_set "$pr_num" merge_base done "merge not needed - branch up to date"
        else
          progress_set "$pr_num" merge_base done "merged origin/$base_branch and pushed"
        fi
        progress_set "$pr_num" resolve_conflicts skipped "not needed"
        return 0
      fi

      echo "[merge] WARNING: push failed after clean merge"
      progress_set "$pr_num" merge_base failed "merged origin/$base_branch but push failed"
      progress_set "$pr_num" resolve_conflicts skipped "not needed"
      return 1
    fi

    echo "[merge] conflicts — auto-resolving..."
    progress_set "$pr_num" merge_base done "conflicts detected"
    progress_set "$pr_num" resolve_conflicts running "auto-resolving"
    local conflicted auto_resolved=0
    conflicted=$(git -C "$worktree_path" diff --name-only --diff-filter=U || true)

    local file
    while IFS= read -r file; do
      [ -n "$file" ] || continue
      case "$file" in
        *.lock|*-lock.yaml|*-lock.json|*.tsbuildinfo)
          git -C "$worktree_path" checkout --theirs "$file" 2>/dev/null
          git -C "$worktree_path" add "$file" 2>/dev/null
          auto_resolved=$((auto_resolved + 1))
          echo "[merge] auto-resolve $file (theirs)" ;;
        .github/workflows/*|.github/docs/*|.github/.auto-fix-iterations|CHANGELOG.md|*/CHANGELOG.md|*/Changelog.md|thread-responses.json)
          git -C "$worktree_path" checkout --ours "$file" 2>/dev/null
          git -C "$worktree_path" add "$file" 2>/dev/null
          auto_resolved=$((auto_resolved + 1))
          echo "[merge] auto-resolve $file (ours)" ;;
      esac
    done <<< "$conflicted"

    local remaining
    remaining=$(git -C "$worktree_path" diff --name-only --diff-filter=U || true)
    if [ -z "$remaining" ]; then
      if ! git -C "$worktree_path" commit --no-edit >/dev/null 2>&1; then
        echo "[merge] auto-resolve commit failed"
        progress_set "$pr_num" resolve_conflicts failed "auto-resolved $auto_resolved file(s), but the merge commit failed"
        return 1
      fi
      if [ "$DRY_RUN" = true ]; then
        echo "[merge] auto-resolved"
        echo "[merge] dry-run: not pushing"
        progress_set "$pr_num" resolve_conflicts done "auto-resolved $auto_resolved file(s) locally (dry-run)"
        return 0
      fi
      if ! git -C "$worktree_path" push --quiet 2>/dev/null; then
        echo "[merge] WARNING: push failed after auto-resolve"
        progress_set "$pr_num" resolve_conflicts failed "auto-resolved $auto_resolved file(s), but push failed"
        return 1
      fi
      echo "[merge] auto-resolved"
      echo "[merge] pushed"
      progress_set "$pr_num" resolve_conflicts done "auto-resolved $auto_resolved file(s) and pushed"
      return 0
    fi

    if [ "$DRY_RUN" = true ]; then
      git -C "$worktree_path" merge --abort 2>/dev/null || true
      git -C "$worktree_path" reset --hard HEAD >/dev/null 2>&1 || true
      git -C "$worktree_path" clean -fd >/dev/null 2>&1 || true
      echo "[merge] dry-run: skipping LLM resolution"
      progress_set "$pr_num" resolve_conflicts skipped "dry-run"
      return 1
    fi

    [ "$AI_BACKEND" = "auto" ] && resolve_ai_backend

    echo "[merge] $remaining — using $AI_BACKEND..."
    local llm_targets
    llm_targets="$(printf '%s\n' "$remaining" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')"
    progress_set "$pr_num" resolve_conflicts running "using $AI_BACKEND for $llm_targets file(s)"
    local prompt="Resolve merge conflicts in: $remaining
Keep both sides where possible. PR branch (ours/HEAD) takes priority.
After resolving: git add each file, git commit --no-edit, git push."

    local llm_succeeded=false
    if [ "$AI_BACKEND" = "claude" ]; then
      (cd "$worktree_path" && claude --dangerously-skip-permissions -p "$prompt" < /dev/null 2>&1 | tail -10) && llm_succeeded=true
    else
      codex exec \
        --cd "$worktree_path" \
        --model "$FIX_MODEL" \
        --dangerously-bypass-approvals-and-sandbox \
        --color never \
        "$prompt" >/dev/null 2>&1 && llm_succeeded=true
    fi

    if [ "$llm_succeeded" = true ]; then
      remaining=$(git -C "$worktree_path" diff --name-only --diff-filter=U || true)
      if [ -z "$remaining" ]; then
        if git -C "$worktree_path" rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
          if ! git -C "$worktree_path" commit --no-edit >/dev/null 2>&1; then
            echo "[merge] merge commit failed after LLM resolution"
            progress_set "$pr_num" resolve_conflicts failed "resolved with $AI_BACKEND but merge commit failed"
            return 1
          fi
        fi

        if git -C "$worktree_path" push --quiet 2>/dev/null; then
          echo "[merge] LLM resolved"
          echo "[merge] pushed"
          if [ "$auto_resolved" -gt 0 ]; then
            progress_set "$pr_num" resolve_conflicts done "auto-resolved $auto_resolved file(s), finished remaining conflicts with $AI_BACKEND, and pushed"
          else
            progress_set "$pr_num" resolve_conflicts done "resolved with $AI_BACKEND and pushed"
          fi
          return 0
        fi

        echo "[merge] WARNING: push failed after LLM resolution"
        progress_set "$pr_num" resolve_conflicts failed "resolved with $AI_BACKEND but push failed"
        return 1
      fi
    fi

    git -C "$worktree_path" merge --abort 2>/dev/null || true
    git -C "$worktree_path" reset --hard HEAD >/dev/null 2>&1 || true
    git -C "$worktree_path" clean -fd >/dev/null 2>&1 || true
    echo "[merge] could not resolve — aborted"
    progress_set "$pr_num" resolve_conflicts failed "manual resolution required"
    return 1
  } >> "$log_file" 2>&1
}

# ── committed conflict marker detection + fix ────────────────────────────────

fix_committed_conflict_markers() {
  local pr_num="$1" worktree_path="$2" log_file="$3"

  {
    local conflict_files
    conflict_files="$(git -C "$worktree_path" grep -Il "^<<<<<<< " 2>/dev/null || true)"

    [ -z "$conflict_files" ] && return 0

    local count
    count="$(echo "$conflict_files" | wc -l | tr -d ' ')"
    echo "[conflict-markers] $count file(s) with committed conflict markers: $(echo "$conflict_files" | tr '\n' ' ')"
    progress_set "$pr_num" resolve_conflicts running "fixing $count committed conflict marker(s)"

    [ "$AI_BACKEND" = "auto" ] && resolve_ai_backend

    local prompt="The following files have git merge conflict markers (<<<<<<< HEAD, =======, >>>>>>>) that were accidentally committed to the branch. Fix each file by resolving the conflicts properly:
$conflict_files

For each file:
1. Read the file and find all conflict marker sections
2. Resolve each conflict — prefer the HEAD/PR-branch version (between <<<<<<< HEAD and =======) unless the other side is clearly an improvement
3. Remove all conflict marker lines (<<<<<<< HEAD, =======, >>>>>>> ...)
4. Save the file and run: git add <file>

After all files are fixed: git commit -m 'fix: resolve committed conflict markers' && git push"

    local llm_succeeded=false
    if [ "$AI_BACKEND" = "claude" ]; then
      (cd "$worktree_path" && claude --dangerously-skip-permissions -p "$prompt" < /dev/null 2>&1) && llm_succeeded=true
    else
      codex exec \
        --cd "$worktree_path" \
        --model "$FIX_MODEL" \
        --dangerously-bypass-approvals-and-sandbox \
        --color never \
        "$prompt" >/dev/null 2>&1 && llm_succeeded=true
    fi

    if [ "$llm_succeeded" = true ]; then
      local remaining
      remaining="$(git -C "$worktree_path" grep -Il "^<<<<<<< " \
        2>/dev/null || true)"
      if [ -z "$remaining" ]; then
        echo "[conflict-markers] fixed all $count file(s)"
        progress_set "$pr_num" resolve_conflicts done "fixed $count committed conflict marker(s)"
        return 0
      fi
      echo "[conflict-markers] LLM ran but markers remain in: $(echo "$remaining" | tr '\n' ' ')"
    else
      echo "[conflict-markers] LLM failed to run"
    fi

    progress_set "$pr_num" resolve_conflicts failed "committed conflict markers could not be auto-fixed"
    return 1
  } >> "$log_file" 2>&1
}

# ── post-fix cycle + summary ─────────────────────────────────────────────────

post_fix_summary() {
  local pr_num="$1" triage_file="$2" responses_file="$3" log_file="$4"
  [ "$DRY_RUN" = true ] && return 0

  {
    local skip_ct auto_ct fixed_ct llm_ct total_ct resolved
    skip_ct="$(jq '.skip | length' < "$triage_file")"
    auto_ct="$(jq '.auto | length' < "$triage_file")"
    fixed_ct="$(jq '.already_likely_fixed | length' < "$triage_file")"
    llm_ct="$(jq '.needs_llm | length' < "$triage_file")"
    total_ct="$(jq '.all | length' < "$triage_file")"
    resolved=0
    [ -f "$responses_file" ] && resolved=$(jq '[.[] | select(.action == "fixed" or .action == "already_fixed")] | length' < "$responses_file" 2>/dev/null || echo "0")

    printf -v body '%s\n' \
      "🤖 **gh crfix** — Fix Summary" "" \
      "| Stage | Count |" "|-------|-------|" \
      "| Total threads | $total_ct |" \
      "| Skipped (deterministic) | $skip_ct |" \
      "| Already likely fixed | $fixed_ct |" \
      "| Auto/mechanical | $auto_ct |" \
      "| Sent to LLM | $llm_ct |" \
      "| Resolved | $resolved |"

    pr_comment "$pr_num" "$body"
    echo "[summary] posted"
  } >> "$log_file" 2>&1
}

post_fix_review_cycle() {
  local pr_num="$1" worktree_path="$2" fixed_count="$3" log_file="$4"
  { [ "$NO_POST_FIX" = true ] || [ "$DRY_RUN" = true ]; } && return 0

  {
    echo "[post-fix] waiting ${REVIEW_WAIT_SECS}s..."
    sleep "$REVIEW_WAIT_SECS"

    local new_threads new_count
    new_threads="$(get_unresolved_threads "$OWNER_REPO" "$pr_num")"
    new_count="$(echo "$new_threads" | jq 'length')"

    if [ "$new_count" -eq 0 ]; then
      echo "[post-fix] no new comments"
      pr_comment "$pr_num" "🤖 **gh crfix**: All $fixed_count comments addressed. No new issues after re-review."
      if ! merge_base_branch "$pr_num" "$worktree_path" "$log_file"; then
        pr_comment "$pr_num" "🤖 **gh crfix**: ⚠️ Could not merge base branch — conflicts require manual resolution."
      fi
      fix_committed_conflict_markers "$pr_num" "$worktree_path" "$log_file" || true
      request_copilot_review "$pr_num"
      echo "[post-fix] done"
    else
      echo "[post-fix] $new_count new comment(s)"
      pr_comment "$pr_num" "🤖 **gh crfix**: Fixed $fixed_count comments, but $new_count new issue(s) raised. Run again to address."
    fi
  } >> "$log_file" 2>&1
}

run_pre_gate_phase() {
  local pr_num="$1" worktree_path="$2" triage_file="$3" hook="$4" validate_runner="$5" log_file="$6"
  local validation_file="$LOG_DIR/pr-$pr_num-validation.json"
  local gate_context="$LOG_DIR/pr-$pr_num-gate-context.json"

  if [ "$NO_AUTOFIX" = true ]; then
    progress_set "$pr_num" autofix skipped "disabled by flag"
  elif [ -z "$hook" ]; then
    progress_set "$pr_num" autofix skipped "no hook configured"
  else
    progress_set "$pr_num" autofix running "${hook##*/}"
    if run_autofix_hook "$worktree_path" "$hook" "$log_file"; then
      progress_set "$pr_num" autofix done "${hook##*/}"
    else
      progress_set "$pr_num" autofix failed "${hook##*/} failed"
    fi
  fi

  if [ -z "$validate_runner" ]; then
    progress_set "$pr_num" validate skipped "no validation configured"
  else
    progress_set "$pr_num" validate running "${validate_runner#*::}"
  fi
  run_validation "$worktree_path" "$validate_runner" "$validation_file" "$log_file"
  if [ -f "$validation_file" ]; then
    if [ "$(jq -r '.tests_failed // false' < "$validation_file")" = "true" ]; then
      progress_set "$pr_num" validate failed "$(jq -r '.summary // "validation failed"' < "$validation_file")"
    else
      progress_set "$pr_num" validate done "$(jq -r '.summary // "validation passed"' < "$validation_file")"
    fi
  fi
  build_gate_context "$triage_file" "$validation_file" "$gate_context"

  {
    echo "[score] $(cat "$gate_context")"
  } >> "$log_file" 2>&1
}

