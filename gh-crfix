#!/usr/bin/env bash
# gh crfix — hybrid PR review fixer
#
# Strategy:
#   1) deterministic triage
#   2) optional repo-local autofix hook
#   3) deterministic validation + score threshold
#   4) gate model decides whether advanced model is needed
#   5) advanced model only for residual hard cases
#   6) post-fix review cycle + merge base branch
#   7) TUI dashboard for parallel mode
#
# Usage:
#   gh crfix 123
#   gh crfix 123-126
#   gh crfix [123,125,130]
#   gh crfix https://github.com/owner/repo/pull/123
#   gh crfix https://github.com/owner/repo/pull/93-95
#   gh crfix https://github.com/owner/repo/pull/[93,94,95]
#
# Flags:
#   -c N, --concurrency N        max parallel PR workers (default: 3)
#   --ai-backend BACKEND         AI backend: auto|claude|codex (default: auto)
#   --seq                        same as -c 1
#   --no-tui                     disable TUI dashboard (plain output)
#   --no-post-fix                skip post-fix review cycle
#   --setup-only                 only setup worktrees + collect triage
#   --no-resolve                 do not resolve GitHub threads
#   --validate-hook PATH         repo-local deterministic validation script
#   --no-validate                disable validation hook even if present
#   --include-outdated           include outdated unresolved threads in triage
#   --gate-model MODEL           small model for gate (default: sonnet)
#   --fix-model MODEL            advanced model for actual fixing (default: sonnet)
#   --score-needs-llm N          contribution (0..1) when residual semantic review remains
#   --score-pr-comment N         contribution (0..1) when residual PR-level comments remain
#   --score-test-failure N       contribution (0..1) when deterministic validation reports failures
#   --max-threads N              max threads fetched per PR (default: 100)
#   --autofix-hook PATH          repo-local deterministic autofix script
#   --no-autofix                 skip autofix hook even if present
#   --resolve-skipped            also resolve skipped threads
#   --dry-run                    no writes to GitHub, no AI fix run
#   -h, --help
#
# Env:
#   GH_CRFIX_DIR                 override local repo path
#   GH_CRFIX_AI_BACKEND          AI backend override: auto|claude|codex
#   GH_CRFIX_REVIEW_WAIT         seconds to wait for re-review (default: 90)
#   GH_CRFIX_GATE_MODEL          gate model override
#   GH_CRFIX_FIX_MODEL           fix model override
#   GH_CRFIX_SCORE_NEEDS_LLM     score contribution (default: 1)
#   GH_CRFIX_SCORE_PR_COMMENT    score contribution (default: 0.4)
#   GH_CRFIX_SCORE_TEST_FAILURE  score contribution (default: 1)

set -euo pipefail

WORKTREE_SUBDIR=".gh-crfix/worktrees"
OWNER_REPO=""
PR_NUMBERS=""
CONCURRENCY=3
AI_BACKEND="${GH_CRFIX_AI_BACKEND:-auto}"
SETUP_ONLY=false
NO_RESOLVE=false
NO_TUI=false
NO_POST_FIX=false
INCLUDE_OUTDATED=false
GATE_MODEL="${GH_CRFIX_GATE_MODEL:-sonnet}"
FIX_MODEL="${GH_CRFIX_FIX_MODEL:-sonnet}"
MAX_THREADS=100
AUTO_FIX_HOOK=""
VALIDATE_HOOK=""
NO_AUTOFIX=false
NO_VALIDATE=false
RESOLVE_SKIPPED=false
DRY_RUN=false
REVIEW_WAIT_SECS="${GH_CRFIX_REVIEW_WAIT:-90}"
SCORE_NEEDS_LLM="${GH_CRFIX_SCORE_NEEDS_LLM:-1}"
SCORE_PR_COMMENT="${GH_CRFIX_SCORE_PR_COMMENT:-0.4}"
SCORE_TEST_FAILURE="${GH_CRFIX_SCORE_TEST_FAILURE:-1}"
LAUNCH_FROM_TUI=false
LOG_DIR=""
SEMAPHORE=""
BG_PIDS=""

# ── Helpers ──────────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

is_number_0_to_1() {
  local value="${1:-}"
  echo "$value" | grep -Eq '^(0(\.[0-9]+)?|1(\.0+)?|\.[0-9]+)$'
}

validate_score_flag() {
  local name="$1" value="$2"
  is_number_0_to_1 "$value" || die "$name must be a number between 0 and 1"
}

score_sum() {
  awk '
    BEGIN { total = 0 }
    {
      for (i = 1; i <= NF; i++) total += $i + 0
    }
    END { printf "%.3f", total }
  ' <<< "$*"
}

normalize_score() {
  awk -v value="$1" 'BEGIN { printf "%.3f", value + 0 }'
}

score_at_least_one() {
  awk -v total="$1" 'BEGIN { exit !(total + 0 >= 1) }'
}

resolve_ai_backend() {
  case "$AI_BACKEND" in
    auto)
      if command -v claude >/dev/null 2>&1; then
        AI_BACKEND="claude"
      elif command -v codex >/dev/null 2>&1; then
        AI_BACKEND="codex"
      else
        die "Neither 'claude' nor 'codex' CLI is installed. Install one or set --ai-backend."
      fi
      ;;
    claude)
      command -v claude >/dev/null 2>&1 || die "'claude' CLI not found"
      ;;
    codex)
      command -v codex >/dev/null 2>&1 || die "'codex' CLI not found"
      ;;
    *)
      die "Unsupported AI backend: $AI_BACKEND"
      ;;
  esac
}

verify_prereqs() {
  command -v gh >/dev/null 2>&1 || die "'gh' CLI not found"
  command -v jq >/dev/null 2>&1 || die "'jq' not found"
  gh auth status >/dev/null 2>&1 || die "'gh' is not authenticated. Run: gh auth login"
}

# ── tiny fs kv ───────────────────────────────────────────────────────────────

kv_set()    { mkdir -p "$LOG_DIR/kv"; printf '%s' "$3" > "$LOG_DIR/kv/${1}__${2}"; }
kv_get()    { cat "$LOG_DIR/kv/${1}__${2}" 2>/dev/null || true; }
kv_append() { mkdir -p "$LOG_DIR/kv"; echo "$2" >> "$LOG_DIR/kv/list__${1}"; }
kv_list()   { cat "$LOG_DIR/kv/list__${1}" 2>/dev/null || true; }

# ── usage ────────────────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
gh crfix — hybrid PR review fixer (triage + gate + TUI + conflict resolution + post-fix)

Usage:
  gh crfix                  interactive launcher (TTY only)
  gh crfix <url>            single PR
  gh crfix <url-range>      range   e.g. .../pull/93-95
  gh crfix <url-list>       list    e.g. .../pull/[93,94,95]
  gh crfix <number>         uses current repo
  gh crfix <n1>-<n2>        uses current repo
  gh crfix <n1>,<n2>,<n3>   uses current repo

Flags:
  -c N, --concurrency N        max parallel PR workers (default: 3)
  --ai-backend BACKEND         AI backend: auto|claude|codex (default: auto)
  --seq                        sequential mode (same as -c 1)
  --no-tui                     disable TUI dashboard (plain output)
  --no-post-fix                skip post-fix review cycle (wait + merge master)
  --setup-only                 only setup worktrees + collect triage
  --no-resolve                 do not resolve GitHub threads
  --include-outdated           include outdated unresolved threads
  --gate-model MODEL           gate model (default: sonnet)
  --fix-model MODEL            advanced model for fixing (default: sonnet)
  --validate-hook PATH         deterministic validation script
  --no-validate                disable validation hook and built-in test detection
  --score-needs-llm N          contribution (0..1) for residual semantic review
  --score-pr-comment N         contribution (0..1) for residual PR-level comments
  --score-test-failure N       contribution (0..1) for failed deterministic validation
  --max-threads N              max threads fetched per PR (default: 100)
  --autofix-hook PATH          deterministic repo-local autofix script
  --no-autofix                 disable autofix hook
  --resolve-skipped            also resolve skipped threads
  --dry-run                    do not mutate GitHub or push commits

Flow:
  1. Setup      — fetch PR info, create worktrees, merge base branch,
                  get review threads, deterministic triage (sequential)
  2. Autofix    — run repo-local autofix hook if available
  3. Validate   — run deterministic validation/tests and build a gate score
  4. Gate       — ask a smaller model if score >= 1
  5. Fix        — run the advanced model only if gate says yes
                  TUI dashboard shows live progress (parallel mode)
  6. Resolve    — reply to threads, mark resolved, request Copilot re-review
  7. Post-fix   — wait for re-review; if no new comments: merge base branch,
                  add PR comment, request final re-review
  8. Report     — print per-PR summary

Repo autofix discovery:
  - --autofix-hook PATH
  - .gh-crfix/autofix.sh
  - scripts/gh-crfix-autofix.sh

Validation discovery:
  - --validate-hook PATH
  - .gh-crfix/validate.sh
  - scripts/gh-crfix-validate.sh
  - built-in package.json test detection (npm/pnpm/yarn/bun)

Worktrees: <repo>/.gh-crfix/worktrees/pr-{number}

Env vars:
  GH_CRFIX_DIR            force the local repo path (auto-detected otherwise)
  GH_CRFIX_AI_BACKEND     AI backend override: auto|claude|codex
  GH_CRFIX_REVIEW_WAIT    seconds to wait for re-review (default: 90)
  GH_CRFIX_GATE_MODEL     gate model override (default: sonnet)
  GH_CRFIX_FIX_MODEL      fix model override (default: sonnet)
  GH_CRFIX_SCORE_NEEDS_LLM     contribution for residual semantic review (default: 1)
  GH_CRFIX_SCORE_PR_COMMENT    contribution for PR-level comments (default: 0.4)
  GH_CRFIX_SCORE_TEST_FAILURE  contribution for failed validation/tests (default: 1)
EOF
}

# ── parse args ───────────────────────────────────────────────────────────────

parse_flags() {
  local args=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -c|--concurrency)
        shift; CONCURRENCY="${1:?missing value for -c}"
        case "$CONCURRENCY" in *[!0-9]*) die "-c requires a number" ;; esac
        [ "$CONCURRENCY" -ge 1 ] || die "-c must be >= 1"
        ;;
      --ai-backend)
        shift; AI_BACKEND="${1:?missing value}"
        case "$AI_BACKEND" in auto|claude|codex) ;; *) die "--ai-backend must be one of: auto, claude, codex" ;; esac
        ;;
      --seq) CONCURRENCY=1 ;;
      --no-tui) NO_TUI=true ;;
      --no-post-fix) NO_POST_FIX=true ;;
      --setup-only) SETUP_ONLY=true ;;
      --no-resolve) NO_RESOLVE=true ;;
      --include-outdated) INCLUDE_OUTDATED=true ;;
      --gate-model) shift; GATE_MODEL="${1:?missing value}" ;;
      --fix-model) shift; FIX_MODEL="${1:?missing value}" ;;
      --validate-hook) shift; VALIDATE_HOOK="${1:?missing value}" ;;
      --no-validate) NO_VALIDATE=true ;;
      --score-needs-llm)
        shift; SCORE_NEEDS_LLM="${1:?missing value}"
        validate_score_flag "--score-needs-llm" "$SCORE_NEEDS_LLM"
        ;;
      --score-pr-comment)
        shift; SCORE_PR_COMMENT="${1:?missing value}"
        validate_score_flag "--score-pr-comment" "$SCORE_PR_COMMENT"
        ;;
      --score-test-failure)
        shift; SCORE_TEST_FAILURE="${1:?missing value}"
        validate_score_flag "--score-test-failure" "$SCORE_TEST_FAILURE"
        ;;
      --max-threads)
        shift; MAX_THREADS="${1:?missing value}"
        case "$MAX_THREADS" in *[!0-9]*) die "--max-threads requires a number" ;; esac
        [ "$MAX_THREADS" -ge 1 ] || die "--max-threads must be >= 1"
        ;;
      --autofix-hook) shift; AUTO_FIX_HOOK="${1:?missing value}" ;;
      --no-autofix) NO_AUTOFIX=true ;;
      --resolve-skipped) RESOLVE_SKIPPED=true ;;
      --dry-run) DRY_RUN=true ;;
      -h|--help) usage; exit 0 ;;
      *) args="${args:+$args }$1" ;;
    esac
    shift
  done

  validate_score_flag "GH_CRFIX_SCORE_NEEDS_LLM/--score-needs-llm" "$SCORE_NEEDS_LLM"
  validate_score_flag "GH_CRFIX_SCORE_PR_COMMENT/--score-pr-comment" "$SCORE_PR_COMMENT"
  validate_score_flag "GH_CRFIX_SCORE_TEST_FAILURE/--score-test-failure" "$SCORE_TEST_FAILURE"

  [ -n "$args" ] || { usage; exit 0; }
  parse_input "$args"
}

# ── parse input ──────────────────────────────────────────────────────────────

parse_input() {
  local input="$1"
  local pr_part

  if echo "$input" | grep -qE 'github\.com/'; then
    OWNER_REPO="$(echo "$input" | sed -E 's|.*github\.com/([^/]+/[^/]+)/pull/.*|\1|')"
    pr_part="$(echo "$input" | sed -E 's|.*github\.com/[^/]+/[^/]+/pull/||; s|/$||')"
  else
    OWNER_REPO=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null) \
      || die "Not inside a GitHub repo and no URL given."
    pr_part="$(echo "$input" | sed 's|/$||')"
  fi

  pr_part="$(echo "$pr_part" | sed 's/^\[//; s/\]$//')"

  if echo "$pr_part" | grep -qE '^[0-9]+-[0-9]+$'; then
    local s="${pr_part%-*}" e="${pr_part#*-}" i
    PR_NUMBERS=""
    i="$s"
    while [ "$i" -le "$e" ]; do
      PR_NUMBERS="${PR_NUMBERS:+$PR_NUMBERS }$i"
      i=$((i + 1))
    done
  elif echo "$pr_part" | grep -qE '^[0-9]+(,[0-9]+)+$'; then
    PR_NUMBERS="$(echo "$pr_part" | tr ',' ' ')"
  elif echo "$pr_part" | grep -qE '^[0-9]+$'; then
    PR_NUMBERS="$pr_part"
  else
    die "Cannot parse PR number(s) from: $pr_part"
  fi
}

# ── repo discovery ───────────────────────────────────────────────────────────

find_local_repo() {
  local owner_repo="$1"

  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local remote
    remote=$(git remote get-url origin 2>/dev/null || true)
    if echo "$remote" | grep -q "$owner_repo"; then
      git rev-parse --show-toplevel
      return 0
    fi
  fi

  if [ -n "${GH_CRFIX_DIR:-}" ]; then
    echo "$GH_CRFIX_DIR"
    return 0
  fi

  local dir
  for dir in "$HOME/projects" "$HOME/code" "$HOME/dev" "$HOME/work"; do
    [ -d "$dir" ] || continue
    while IFS= read -r git_dir; do
      local repo_dir remote
      repo_dir="$(dirname "$git_dir")"
      remote=$(git -C "$repo_dir" remote get-url origin 2>/dev/null || true)
      if echo "$remote" | grep -q "$owner_repo"; then
        echo "$repo_dir"
        return 0
      fi
    done < <(find "$dir" -maxdepth 4 -name ".git" -type d 2>/dev/null)
  done

  die "Cannot find local clone of $owner_repo. Set GH_CRFIX_DIR=/path/to/repo."
}

# ── autofix hook detection ───────────────────────────────────────────────────

detect_autofix_hook() {
  local repo_dir="$1"

  if [ "$NO_AUTOFIX" = true ]; then
    echo ""
    return 0
  fi

  if [ -n "$AUTO_FIX_HOOK" ]; then
    echo "$AUTO_FIX_HOOK"
    return 0
  fi

  if [ -x "$repo_dir/.gh-crfix/autofix.sh" ]; then
    echo "$repo_dir/.gh-crfix/autofix.sh"
    return 0
  fi

  if [ -x "$repo_dir/scripts/gh-crfix-autofix.sh" ]; then
    echo "$repo_dir/scripts/gh-crfix-autofix.sh"
    return 0
  fi

  echo ""
}

run_autofix_hook() {
  local worktree_path="$1" hook="$2" log_file="$3"

  [ -n "$hook" ] || return 0
  [ -x "$hook" ] || return 0

  {
    echo "[autofix] running: $hook"
    (cd "$worktree_path" && "$hook")
    echo "[autofix] done"
  } >> "$log_file" 2>&1 || {
    echo "[autofix] hook failed (continuing)" >> "$log_file"
    return 0
  }
}

# ── validation detection + execution ────────────────────────────────────────

detect_package_manager() {
  local repo_dir="$1"
  local package_manager=""

  if [ -f "$repo_dir/package.json" ]; then
    package_manager="$(jq -r '.packageManager // empty' < "$repo_dir/package.json" 2>/dev/null || true)"
  fi

  case "$package_manager" in
    pnpm@*) echo "pnpm"; return 0 ;;
    yarn@*) echo "yarn"; return 0 ;;
    bun@*)  echo "bun"; return 0 ;;
    npm@*)  echo "npm"; return 0 ;;
  esac

  if [ -f "$repo_dir/pnpm-lock.yaml" ]; then
    echo "pnpm"
  elif [ -f "$repo_dir/yarn.lock" ]; then
    echo "yarn"
  elif [ -f "$repo_dir/bun.lock" ] || [ -f "$repo_dir/bun.lockb" ]; then
    echo "bun"
  else
    echo "npm"
  fi
}

detect_builtin_test_command() {
  local repo_dir="$1"
  local package_json="$repo_dir/package.json"

  [ -f "$package_json" ] || { echo ""; return 0; }
  jq -e '.scripts.test? | strings | length > 0' < "$package_json" >/dev/null 2>&1 || {
    echo ""
    return 0
  }

  case "$(detect_package_manager "$repo_dir")" in
    pnpm) echo "pnpm test" ;;
    yarn) echo "yarn test" ;;
    bun)  echo "bun run test" ;;
    *)    echo "npm test" ;;
  esac
}

detect_validate_runner() {
  local repo_dir="$1"

  if [ "$NO_VALIDATE" = true ]; then
    echo ""
    return 0
  fi

  if [ -n "$VALIDATE_HOOK" ]; then
    echo "hook::$VALIDATE_HOOK"
    return 0
  fi

  if [ -x "$repo_dir/.gh-crfix/validate.sh" ]; then
    echo "hook::$repo_dir/.gh-crfix/validate.sh"
    return 0
  fi

  if [ -x "$repo_dir/scripts/gh-crfix-validate.sh" ]; then
    echo "hook::$repo_dir/scripts/gh-crfix-validate.sh"
    return 0
  fi

  local builtin_cmd
  builtin_cmd="$(detect_builtin_test_command "$repo_dir")"
  if [ -n "$builtin_cmd" ]; then
    echo "builtin::$builtin_cmd"
    return 0
  fi

  echo ""
}

validation_log_summary() {
  local raw_file="$1" fallback="$2"
  if [ -f "$raw_file" ]; then
    tail -20 "$raw_file" 2>/dev/null \
      | sed '/^[[:space:]]*$/d' \
      | tail -3 \
      | tr '\n' ' ' \
      | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//'
  else
    echo "$fallback"
  fi
}

write_validation_result() {
  local out_file="$1" source_type="$2" source_value="$3" success="$4" tests_failed="$5" summary="$6"

  jq -n \
    --arg source_type "$source_type" \
    --arg source_value "$source_value" \
    --argjson success "$success" \
    --argjson tests_failed "$tests_failed" \
    --arg summary "$summary" \
    '{
      source_type: $source_type,
      source: $source_value,
      available: ($source_type != "none"),
      ran: ($source_type != "none"),
      success: $success,
      tests_failed: $tests_failed,
      summary: $summary
    }' > "$out_file"
}

run_validation() {
  local worktree_path="$1" runner="$2" out_file="$3" log_file="$4"
  local runner_type="${runner%%::*}" runner_value="${runner#*::}"
  local raw_file="$out_file.raw.log"
  local hook_json="$out_file.hook.json"

  if [ -z "$runner" ]; then
    write_validation_result "$out_file" "none" "" true false "No deterministic validation configured."
    return 0
  fi

  rm -f "$raw_file" "$hook_json"

  local exit_code=0
  {
    if [ "$runner_type" = "hook" ]; then
      echo "[validate] running hook: $runner_value"
      (
        cd "$worktree_path" &&
        CI=1 GH_CRFIX_VALIDATION_OUT="$hook_json" "$runner_value"
      ) > "$raw_file" 2>&1 || exit_code=$?
    else
      echo "[validate] running builtin tests: $runner_value"
      (
        cd "$worktree_path" &&
        CI=1 bash -lc "$runner_value"
      ) > "$raw_file" 2>&1 || exit_code=$?
    fi

    [ -f "$raw_file" ] && cat "$raw_file"
    echo "[validate] exit=$exit_code"
  } >> "$log_file" 2>&1

  if [ -f "$hook_json" ] && jq -e '.' "$hook_json" >/dev/null 2>&1; then
    jq -n \
      --arg source_type "$runner_type" \
      --arg source_value "$runner_value" \
      --argjson fallback_success "$( [ "$exit_code" -eq 0 ] && echo true || echo false )" \
      --argjson fallback_tests_failed "$( [ "$exit_code" -eq 0 ] && echo false || echo true )" \
      --arg fallback_summary "$(validation_log_summary "$raw_file" "Validation hook completed.")" \
      --slurpfile hook "$hook_json" '
      ($hook[0] // {}) as $doc |
      {
        source_type: $source_type,
        source: $source_value,
        available: true,
        ran: true,
        success: ($doc.success // $fallback_success),
        tests_failed: ($doc.tests_failed // $fallback_tests_failed),
        summary: ($doc.summary // $fallback_summary)
      }' > "$out_file"
    return 0
  fi

  if [ "$exit_code" -eq 0 ]; then
    write_validation_result \
      "$out_file" "$runner_type" "$runner_value" true false \
      "$(validation_log_summary "$raw_file" "Deterministic validation passed.")"
  else
    write_validation_result \
      "$out_file" "$runner_type" "$runner_value" false true \
      "$(validation_log_summary "$raw_file" "Deterministic validation failed.")"
  fi
}

# ── worktree setup ───────────────────────────────────────────────────────────

setup_worktree() {
  local pr_num="$1" repo_dir="$2" branch="$3"
  local worktree_path="$repo_dir/$WORKTREE_SUBDIR/pr-$pr_num"

  mkdir -p "$repo_dir/$WORKTREE_SUBDIR"

  if git -C "$repo_dir" worktree list --porcelain | grep -qxF "worktree $worktree_path"; then
    # Clean up any leftover state from previous run
    git -C "$worktree_path" merge --abort 2>/dev/null || true
    git -C "$worktree_path" rebase --abort 2>/dev/null || true
    git -C "$worktree_path" checkout -- . 2>/dev/null || true
    git -C "$worktree_path" clean -fd 2>/dev/null || true
    git -C "$worktree_path" fetch origin "$branch" --quiet || true
    git -C "$worktree_path" checkout "$branch" 2>/dev/null || true
    git -C "$worktree_path" reset --hard "origin/$branch" 2>/dev/null || true
    echo "$worktree_path"
    return 0
  fi

  local existing_wt
  existing_wt=$(git -C "$repo_dir" worktree list --porcelain \
    | awk -v b="$branch" '/^worktree /{wt=$2} /^branch refs\/heads\//{if($2=="refs/heads/"b) print wt}')

  if [ -n "$existing_wt" ]; then
    git -C "$existing_wt" merge --abort 2>/dev/null || true
    git -C "$existing_wt" rebase --abort 2>/dev/null || true
    git -C "$existing_wt" checkout -- . 2>/dev/null || true
    git -C "$existing_wt" clean -fd 2>/dev/null || true
    git -C "$existing_wt" fetch origin "$branch" --quiet || true
    git -C "$existing_wt" reset --hard "origin/$branch" 2>/dev/null || true
    echo "$existing_wt"
    return 0
  fi

  git -C "$repo_dir" fetch origin "$branch" --quiet 2>/dev/null || true
  if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo_dir" worktree add "$worktree_path" "$branch" >/dev/null 2>&1
  else
    git -C "$repo_dir" worktree add "$worktree_path" \
      --track -b "$branch" "origin/$branch" >/dev/null 2>&1
  fi
  echo "$worktree_path"
}

# ── GitHub API helpers ───────────────────────────────────────────────────────

get_unresolved_threads() {
  local owner_repo="$1" pr_number="$2"
  local owner="${owner_repo%%/*}"
  local repo="${owner_repo##*/}"
  local filter

  if [ "$INCLUDE_OUTDATED" = true ]; then
    filter='[.data.repository.pullRequest.reviewThreads.nodes[] | select(.isResolved == false)]'
  else
    filter='[.data.repository.pullRequest.reviewThreads.nodes[] | select(.isResolved == false and .isOutdated == false)]'
  fi

  gh api graphql -f query='
    query($owner: String!, $repo: String!, $pr: Int!, $threads: Int!) {
      repository(owner: $owner, name: $repo) {
        pullRequest(number: $pr) {
          reviewThreads(first: $threads) {
            nodes {
              id
              isResolved
              isOutdated
              line
              path
              comments(first: 20) {
                nodes {
                  id
                  body
                  path
                  line
                  originalLine
                  author { login }
                  createdAt
                }
              }
            }
          }
        }
      }
    }
  ' -F owner="$owner" -F repo="$repo" -F pr="$pr_number" -F threads="$MAX_THREADS" \
    --jq "$filter"
}

reply_to_thread() {
  local thread_id="$1" body="$2"
  [ "$DRY_RUN" = true ] && return 0

  gh api graphql -f query='
    mutation($threadId: ID!, $body: String!) {
      addPullRequestReviewThreadReply(input: {pullRequestReviewThreadId: $threadId, body: $body}) {
        comment { id }
      }
    }
  ' -F threadId="$thread_id" -F body="$body" --silent
}

resolve_thread() {
  local thread_id="$1"
  [ "$DRY_RUN" = true ] && return 0

  gh api graphql -f query='
    mutation($threadId: ID!) {
      resolveReviewThread(input: {threadId: $threadId}) {
        thread { isResolved }
      }
    }
  ' -F threadId="$thread_id" --silent
}

request_copilot_review() {
  local pr_num="$1"
  [ "$DRY_RUN" = true ] && return 0
  gh api --method POST "/repos/$OWNER_REPO/pulls/$pr_num/requested_reviewers" \
    -f 'reviewers[]=Copilot' >/dev/null 2>&1 || true
}

pr_comment() {
  local pr_num="$1" body="$2"
  [ "$DRY_RUN" = true ] && return 0
  gh pr comment "$pr_num" --repo "$OWNER_REPO" --body "$body" >/dev/null 2>&1 || true
}

# ── deterministic triage ─────────────────────────────────────────────────────

comment_text_for_thread() {
  local thread_json="$1"
  jq -r '
    [
      .comments.nodes[]?.body // empty
    ] | join("\n---\n")
  ' <<< "$thread_json"
}

thread_primary_path() {
  local thread_json="$1"
  jq -r '.comments.nodes[0].path // .path // ""' <<< "$thread_json"
}

thread_primary_line() {
  local thread_json="$1"
  jq -r '.comments.nodes[0].line // .comments.nodes[0].originalLine // .line // 0' <<< "$thread_json"
}

thread_last_created_at() {
  local thread_json="$1"
  jq -r '[.comments.nodes[]?.createdAt] | map(select(. != null)) | last // ""' <<< "$thread_json"
}

file_changed_after_comment() {
  local worktree_path="$1" file="$2" ts="$3"
  [ -n "$file" ] || return 1
  [ -f "$worktree_path/$file" ] || return 1
  [ -n "$ts" ] || return 1
  git -C "$worktree_path" log --since="$ts" --format='%H' -- "$file" 2>/dev/null | head -1 | grep -q .
}

is_question_only() {
  local text="$1"
  local compact
  compact="$(echo "$text" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')"

  echo "$compact" | grep -qiE '(could you|can you|why|what about|do we need|is this intentional|question|clarify)' || return 1
  echo "$compact" | grep -qE '\?$' || return 1
  echo "$compact" | grep -qiE '(rename|change|fix|remove|add|use|should|must|please|nit:|typo|format|lint)' && return 1
  return 0
}

is_simple_mechanical() {
  local text="$1"
  echo "$text" | grep -qiE \
    '(nit:|typo|spelling|grammar|format|formatting|prettier|eslint|lint|import order|unused import|sort imports|whitespace|newline|changelog|snapshot|generated file|docs?)'
}

is_non_actionable() {
  local text="$1"
  # Only skip very short comments that are purely acknowledgements
  local word_count
  word_count="$(echo "$text" | wc -w | tr -d ' ')"
  [ "$word_count" -gt 8 ] && return 1
  echo "$text" | grep -qiE '(^lgtm$|^looks good|^thanks!?$|^nice!?$|great catch|^resolved\??$)'
}

classify_one_thread() {
  local worktree_path="$1" thread_json="$2"
  local id path line text created
  id="$(jq -r '.id' <<< "$thread_json")"
  path="$(thread_primary_path "$thread_json")"
  line="$(thread_primary_line "$thread_json")"
  text="$(comment_text_for_thread "$thread_json")"
  created="$(thread_last_created_at "$thread_json")"

  local reason="needs semantic review"
  local decision="needs_llm"
  local resolve_when_skipped=false

  if [ "$(jq -r '.isOutdated' <<< "$thread_json")" = "true" ] && [ "$INCLUDE_OUTDATED" = false ]; then
    decision="skip"
    reason="outdated thread"
  elif [ -z "$path" ]; then
    decision="needs_llm"
    reason="PR-level comment (no file path)"
  elif is_non_actionable "$text"; then
    decision="skip"
    reason="non-actionable comment"
    resolve_when_skipped=true
  elif is_question_only "$text"; then
    decision="skip"
    reason="question-only thread"
  elif [ ! -e "$worktree_path/$path" ]; then
    decision="skip"
    reason="file no longer exists in worktree"
  elif file_changed_after_comment "$worktree_path" "$path" "$created"; then
    if is_simple_mechanical "$text"; then
      decision="already_likely_fixed"
      reason="file changed after comment and issue looks mechanical"
    fi
  elif is_simple_mechanical "$text"; then
    decision="auto"
    reason="mechanical/simple comment"
  fi

  jq -n \
    --arg id "$id" \
    --arg path "$path" \
    --argjson line "${line:-0}" \
    --arg decision "$decision" \
    --arg reason "$reason" \
    --arg body "$text" \
    --argjson resolve_when_skipped "$resolve_when_skipped" \
    '{
      thread_id: $id,
      path: $path,
      line: $line,
      decision: $decision,
      reason: $reason,
      body: $body,
      resolve_when_skipped: $resolve_when_skipped
    }'
}

triage_threads() {
  local worktree_path="$1" threads_file="$2" out_file="$3"

  local tmp="$LOG_DIR/triage.tmp.jsonl"
  : > "$tmp"

  local count i
  count="$(jq 'length' < "$threads_file")"
  i=0
  while [ "$i" -lt "$count" ]; do
    local one
    one="$(jq -c ".[$i]" < "$threads_file")"
    classify_one_thread "$worktree_path" "$one" >> "$tmp"
    i=$((i + 1))
  done

  jq -s '
    {
      all: .,
      skip: [ .[] | select(.decision == "skip") ],
      auto: [ .[] | select(.decision == "auto") ],
      already_likely_fixed: [ .[] | select(.decision == "already_likely_fixed") ],
      needs_llm: [ .[] | select(.decision == "needs_llm") ]
    }
  ' "$tmp" > "$out_file"
}

# ── gate scoring + gate model ───────────────────────────────────────────────

build_gate_context() {
  local triage_file="$1" validation_file="$2" out_file="$3"
  local needs_llm_count pr_comment_count validation_failed
  local needs_llm_score pr_comment_score test_failure_score total
  local needs_llm_weight pr_comment_weight test_failure_weight

  needs_llm_count="$(jq '.needs_llm | length' < "$triage_file")"
  pr_comment_count="$(jq '[.needs_llm[]? | select(.reason == "PR-level comment (no file path)")] | length' < "$triage_file")"
  validation_failed="$(jq -r '.tests_failed // false' < "$validation_file" 2>/dev/null || echo false)"
  needs_llm_weight="$(normalize_score "$SCORE_NEEDS_LLM")"
  pr_comment_weight="$(normalize_score "$SCORE_PR_COMMENT")"
  test_failure_weight="$(normalize_score "$SCORE_TEST_FAILURE")"

  if [ "$needs_llm_count" -gt 0 ]; then
    needs_llm_score="$needs_llm_weight"
  else
    needs_llm_score="0.000"
  fi

  if [ "$pr_comment_count" -gt 0 ]; then
    pr_comment_score="$pr_comment_weight"
  else
    pr_comment_score="0.000"
  fi

  if [ "$validation_failed" = "true" ]; then
    test_failure_score="$test_failure_weight"
  else
    test_failure_score="0.000"
  fi

  total="$(score_sum "$needs_llm_score" "$pr_comment_score" "$test_failure_score")"

  jq -n \
    --argjson needs_llm_count "$needs_llm_count" \
    --argjson pr_comment_count "$pr_comment_count" \
    --argjson validation_failed "$validation_failed" \
    --argjson needs_llm_weight "$needs_llm_weight" \
    --argjson pr_comment_weight "$pr_comment_weight" \
    --argjson test_failure_weight "$test_failure_weight" \
    --argjson needs_llm_score "$needs_llm_score" \
    --argjson pr_comment_score "$pr_comment_score" \
    --argjson test_failure_score "$test_failure_score" \
    --argjson total "$total" \
    --argjson should_run_gate "$(score_at_least_one "$total" && echo true || echo false)" \
    '{
      threshold: 1,
      total_score: $total,
      should_run_gate: $should_run_gate,
      components: {
        needs_llm: {
          count: $needs_llm_count,
          weight: $needs_llm_weight,
          score: $needs_llm_score
        },
        pr_comment: {
          count: $pr_comment_count,
          weight: $pr_comment_weight,
          score: $pr_comment_score
        },
        test_failure: {
          failed: $validation_failed,
          weight: $test_failure_weight,
          score: $test_failure_score
        }
      }
    }' > "$out_file"
}

gate_schema() {
  cat <<'JSON'
{
  "type": "object",
  "properties": {
    "needs_advanced_model": { "type": "boolean" },
    "reason": { "type": "string" },
    "threads_to_fix": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["needs_advanced_model", "reason", "threads_to_fix"],
  "additionalProperties": false
}
JSON
}

build_gate_prompt() {
  local owner_repo="$1" pr_num="$2" triage_file="$3" validation_file="${4:-}" score_file="${5:-}"

  local auto_ct skip_ct fixed_ct llm_ct
  auto_ct="$(jq '.auto | length' < "$triage_file")"
  skip_ct="$(jq '.skip | length' < "$triage_file")"
  fixed_ct="$(jq '.already_likely_fixed | length' < "$triage_file")"
  llm_ct="$(jq '.needs_llm | length' < "$triage_file")"

  local validation_summary="No deterministic validation data."
  local validation_failed="false"
  local total_score="0"
  local should_run_gate="false"
  local needs_llm_score="0"
  local pr_comment_score="0"
  local test_failure_score="0"

  if [ -n "$validation_file" ] && [ -f "$validation_file" ]; then
    validation_summary="$(jq -r '.summary // "No deterministic validation data."' < "$validation_file")"
    validation_failed="$(jq -r '.tests_failed // false' < "$validation_file")"
  fi

  if [ -n "$score_file" ] && [ -f "$score_file" ]; then
    total_score="$(jq -r '.total_score // 0' < "$score_file")"
    should_run_gate="$(jq -r '.should_run_gate // false' < "$score_file")"
    needs_llm_score="$(jq -r '.components.needs_llm.score // 0' < "$score_file")"
    pr_comment_score="$(jq -r '.components.pr_comment.score // 0' < "$score_file")"
    test_failure_score="$(jq -r '.components.test_failure.score // 0' < "$score_file")"
  fi

  cat <<EOF
You are a gating model for PR review comment automation.

Goal:
Decide whether an advanced coding model should run to fix the remaining review threads and/or deterministic validation failures.

Rules:
- Default to true (send to advanced model) unless you are confident the threads need no code changes.
- Say false ONLY when ALL remaining threads are: clearly already addressed in the PR, pure praise/thanks, or trivially non-actionable (e.g. "LGTM").
- If deterministic validation failed, strongly bias toward true unless the failure is clearly irrelevant noise.
- Say true for anything involving: bugs, security issues, failing tests, missing tests, logic errors, missing validation, unused imports that need removal, refactoring requests, or any thread where code should change.
- Output ONLY valid JSON matching the schema.

Context:
Repo: $owner_repo
PR: #$pr_num

Deterministic triage summary:
- skipped: $skip_ct
- auto/mechanical: $auto_ct
- already_likely_fixed: $fixed_ct
- residual needs_llm candidates: $llm_ct

Deterministic validation:
- tests_failed: $validation_failed
- summary: $validation_summary

Score before gate:
- needs_llm contribution: $needs_llm_score
- pr_comment contribution: $pr_comment_score
- test_failure contribution: $test_failure_score
- total: $total_score
- threshold met: $should_run_gate

Residual candidate threads:
$(jq -r '
  .needs_llm[]
  | "Thread ID: \(.thread_id)\nFile: \(.path)\nLine: \(.line)\nReason: \(.reason)\nBody:\n\(.body)\n---"
' < "$triage_file")

Return:
{
  "needs_advanced_model": true|false,
  "reason": "short explanation",
  "threads_to_fix": ["thread-id-1", "thread-id-2"]
}

If zero residual candidates, return false and empty array.
EOF
}

run_gate_model() {
  local owner_repo="$1" pr_num="$2" triage_file="$3" validation_file="$4" score_file="$5" out_file="$6" log_file="$7"
  local prompt_file="$LOG_DIR/gate-$pr_num.txt"
  local schema_file="$LOG_DIR/gate-$pr_num.schema.json"

  build_gate_prompt "$owner_repo" "$pr_num" "$triage_file" "$validation_file" "$score_file" > "$prompt_file"
  gate_schema > "$schema_file"

  {
    echo "[gate] model=$GATE_MODEL"
    echo "[gate] backend=$AI_BACKEND"
    [ -f "$score_file" ] && echo "[gate] score: $(cat "$score_file")"
    local raw_out="$LOG_DIR/gate-$pr_num.raw.txt"
    local cmd_failed=false
    if [ "$AI_BACKEND" = "claude" ]; then
      claude -p \
        --model "$GATE_MODEL" \
        --output-format text \
        --json-schema "$(cat "$schema_file")" \
        < "$prompt_file" > "$raw_out" || cmd_failed=true
    else
      codex exec \
        --model "$GATE_MODEL" \
        --sandbox read-only \
        --skip-git-repo-check \
        --color never \
        --output-schema "$schema_file" \
        --output-last-message "$raw_out" \
        - < "$prompt_file" >/dev/null || cmd_failed=true
    fi

    if [ "$cmd_failed" = true ]; then
      echo "[gate] failed; fallback to needs_advanced_model=true"
      jq -n \
        --arg reason "gate model failed" \
        '{needs_advanced_model: true, reason: $reason, threads_to_fix: []}' > "$out_file"
    fi

    if [ ! -f "$out_file" ]; then
      # Strip any accidental code fences and parse as JSON
      sed 's/^```json//; s/^```//; s/```$//' < "$raw_out" \
        | jq '.' > "$out_file" 2>/dev/null \
        || {
          echo "[gate] parse failed; fallback to needs_advanced_model=true"
          jq -n --arg reason "gate output not valid JSON" \
            '{needs_advanced_model: true, reason: $reason, threads_to_fix: []}' > "$out_file"
        }
    fi
    echo "[gate] result: $(cat "$out_file")"
  } >> "$log_file" 2>&1
}

# ── advanced fixer ───────────────────────────────────────────────────────────

build_fix_prompt() {
  local owner_repo="$1" pr_num="$2" threads_file="$3" selected_file="$4" validation_file="${5:-}"

  local validation_summary="No deterministic validation data."
  local validation_failed="false"
  if [ -n "$validation_file" ] && [ -f "$validation_file" ]; then
    validation_summary="$(jq -r '.summary // "No deterministic validation data."' < "$validation_file")"
    validation_failed="$(jq -r '.tests_failed // false' < "$validation_file")"
  fi

  cat <<EOF
You are fixing unresolved PR review threads and deterministic validation failures.

Repo: $owner_repo
PR: #$pr_num

Rules:
1. Read AGENTS.md and CLAUDE.md first if present.
2. Work on the selected threads below. If the selected thread list is empty, focus on deterministic validation failures instead.
3. Prefer minimal, correct changes.
4. Skip threads that truly do not require code changes.
5. If you edit files, stage, commit, and push.
6. Write thread-responses.json in repo root with one entry for each selected thread:
   [
     {
       "thread_id": "PRRT_xxx",
       "action": "fixed|skipped|already_fixed",
       "comment": "Concise explanation"
     }
   ]
7. Do NOT include threads outside the selected set.
8. If no code changes are needed, still write thread-responses.json.
9. If deterministic validation failed, run the relevant tests/checks again after your fix if feasible.

Selected thread IDs:
$(cat "$selected_file")

Deterministic validation:
- tests_failed: $validation_failed
- summary: $validation_summary

Selected thread details:
$(jq -r --arg ids "$(cat "$selected_file")" '
  ($ids | split("\n") | map(select(length > 0))) as $idlist |
  .[]
  | select(.id as $id | ($idlist | index($id)))
  | "Thread ID: \(.id)\nFile: \(.comments.nodes[0].path // .path // "unknown")\nLine: \(.comments.nodes[0].line // .comments.nodes[0].originalLine // .line // "unknown")\nComments:\n" +
    ([.comments.nodes[] | "  @\(.author.login): \(.body)"] | join("\n")) + "\n---"
' < "$threads_file")

When done:
- git status
- if changed: git add -A && git commit -m "fix: address PR #$pr_num review comments" && git push
- print short summary
EOF
}

run_fix_model() {
  local owner_repo="$1" pr_num="$2" worktree_path="$3" threads_file="$4" selected_file="$5" validation_file="$6" log_file="$7"
  local prompt_file="$LOG_DIR/fix-$pr_num.txt"

  build_fix_prompt "$owner_repo" "$pr_num" "$threads_file" "$selected_file" "$validation_file" > "$prompt_file"

  {
    echo "[fix] model=$FIX_MODEL"
    echo "[fix] backend=$AI_BACKEND"
    echo "[fix] selected threads:"
    cat "$selected_file"
    echo ""

    local cmd_failed=false
    if [ "$AI_BACKEND" = "claude" ]; then
      (cd "$worktree_path" && claude -p --model "$FIX_MODEL" --dangerously-skip-permissions < "$prompt_file") || cmd_failed=true
    else
      codex exec \
        --cd "$worktree_path" \
        --model "$FIX_MODEL" \
        --dangerously-bypass-approvals-and-sandbox \
        --color never \
        - < "$prompt_file" || cmd_failed=true
    fi

    if [ "$cmd_failed" = true ]; then
      echo "[fix] FAILED"
      return 1
    fi
    echo "[fix] done"
  } >> "$log_file" 2>&1
}

# ── reply / resolve ──────────────────────────────────────────────────────────

reply_and_resolve_from_responses() {
  local responses_file="$1"
  local resolved=0 replied=0 skipped=0

  [ -f "$responses_file" ] || return 0
  jq -e '.' "$responses_file" >/dev/null 2>&1 || return 0

  local n i
  n="$(jq 'length' < "$responses_file")"
  i=0
  while [ "$i" -lt "$n" ]; do
    local tid action comment resolve_when_skipped
    tid="$(jq -r ".[$i].thread_id // empty" < "$responses_file")"
    action="$(jq -r ".[$i].action // empty" < "$responses_file")"
    comment="$(jq -r ".[$i].comment // empty" < "$responses_file")"
    resolve_when_skipped="$(jq -r ".[$i].resolve_when_skipped // false" < "$responses_file")"

    [ -n "$tid" ] || { i=$((i + 1)); continue; }

    if [ -n "$comment" ]; then
      reply_to_thread "$tid" "$comment" && replied=$((replied + 1))
    fi

    case "$action" in
      fixed|already_fixed)
        resolve_thread "$tid" && resolved=$((resolved + 1))
        ;;
      skipped)
        if [ "$RESOLVE_SKIPPED" = true ] || [ "$resolve_when_skipped" = true ]; then
          resolve_thread "$tid" && resolved=$((resolved + 1))
        else
          skipped=$((skipped + 1))
        fi
        ;;
      *)
        skipped=$((skipped + 1))
        ;;
    esac

    i=$((i + 1))
  done

  echo "replied=$replied resolved=$resolved unresolved_skipped=$skipped"
}

write_deterministic_responses() {
  local triage_file="$1" out_file="$2"

  jq '
    [
      (.already_likely_fixed[]? | {
        thread_id: .thread_id,
        action: "already_fixed",
        comment: ("Likely already addressed: " + .reason + ".")
      }),
      (.skip[]? | {
        thread_id: .thread_id,
        action: "skipped",
        comment: ("Skipped automatically: " + .reason + "."),
        resolve_when_skipped: (.resolve_when_skipped // false)
      })
    ]
  ' < "$triage_file" > "$out_file"
}

write_uncovered_responses() {
  local triage_file="$1" selected_file="$2" existing_file="$3" out_file="$4"
  local selected_json="$LOG_DIR/selected-ids.json"

  if [ -f "$selected_file" ]; then
    jq -Rsc 'split("\n") | map(select(length > 0))' < "$selected_file" > "$selected_json"
  else
    echo '[]' > "$selected_json"
  fi

  jq -n \
    --slurpfile triage "$triage_file" \
    --slurpfile existing "$existing_file" \
    --slurpfile selected "$selected_json" '
    ($triage[0]) as $triage_doc |
    (($existing[0] // []) | map(.thread_id)) as $covered |
    ($selected[0] // []) as $selected_ids |
    [
      ($triage_doc.auto[]? | select(($covered | index(.thread_id)) | not) | {
        thread_id: .thread_id,
        action: "skipped",
        comment: ("Not auto-fixed: " + .reason + ". Leaving unresolved for manual follow-up.")
      }),
      ($triage_doc.needs_llm[]? | select(($covered | index(.thread_id)) | not) | {
        thread_id: .thread_id,
        action: "skipped",
        comment: (
          if ($selected_ids | index(.thread_id)) then
            "Automation did not apply a code change for this thread. Leaving unresolved for manual follow-up."
          else
            "Automation did not select this thread for automatic code changes. Leaving unresolved for manual follow-up."
          end
        )
      })
    ]
  ' > "$out_file"
}

# ── conflict resolution ──────────────────────────────────────────────────────

merge_base_branch() {
  local pr_num="$1" worktree_path="$2" log_file="$3"
  local base_branch
  base_branch=$(gh pr view "$pr_num" --repo "$OWNER_REPO" --json baseRefName -q '.baseRefName' 2>/dev/null || echo "master")

  {
    echo "[merge] fetching origin/$base_branch"
    if ! git -C "$worktree_path" fetch origin "+refs/heads/$base_branch:refs/remotes/origin/$base_branch" --quiet 2>&1; then
      echo "[merge] WARNING: fetch failed — will use cached origin/$base_branch"
    fi
    echo "[merge] merging origin/$base_branch"
    if git -C "$worktree_path" merge "origin/$base_branch" --no-edit -q 2>/dev/null; then
      git -C "$worktree_path" push --quiet 2>/dev/null || true
      echo "[merge] clean"
      return 0
    fi

    echo "[merge] conflicts — auto-resolving..."
    local conflicted
    conflicted=$(git -C "$worktree_path" diff --name-only --diff-filter=U || true)

    local file
    while IFS= read -r file; do
      [ -n "$file" ] || continue
      case "$file" in
        *.lock|*-lock.yaml|*-lock.json|*.tsbuildinfo)
          git -C "$worktree_path" checkout --theirs "$file" 2>/dev/null
          git -C "$worktree_path" add "$file" 2>/dev/null
          echo "[merge] auto-resolve $file (theirs)" ;;
        .github/workflows/*|.github/docs/*|.github/.auto-fix-iterations|CHANGELOG.md|thread-responses.json)
          git -C "$worktree_path" checkout --ours "$file" 2>/dev/null
          git -C "$worktree_path" add "$file" 2>/dev/null
          echo "[merge] auto-resolve $file (ours)" ;;
      esac
    done <<< "$conflicted"

    local remaining
    remaining=$(git -C "$worktree_path" diff --name-only --diff-filter=U || true)
    if [ -z "$remaining" ]; then
      git -C "$worktree_path" commit --no-edit >/dev/null 2>&1
      git -C "$worktree_path" push --quiet 2>/dev/null || true
      echo "[merge] auto-resolved"
      return 0
    fi

    if [ "$DRY_RUN" = true ]; then
      git -C "$worktree_path" merge --abort 2>/dev/null || true
      echo "[merge] dry-run: skipping LLM resolution"
      return 1
    fi

    echo "[merge] $remaining — using $AI_BACKEND..."
    local prompt="Resolve merge conflicts in: $remaining
Keep both sides where possible. PR branch (ours/HEAD) takes priority.
After resolving: git add each file, git commit --no-edit, git push."

    local llm_succeeded=false
    if [ "$AI_BACKEND" = "claude" ]; then
      (cd "$worktree_path" && claude --dangerously-skip-permissions -p "$prompt" < /dev/null 2>&1 | tail -10) && llm_succeeded=true
    else
      codex exec \
        --cd "$worktree_path" \
        --model "$FIX_MODEL" \
        --dangerously-bypass-approvals-and-sandbox \
        --color never \
        "$prompt" >/dev/null 2>&1 && llm_succeeded=true
    fi

    if [ "$llm_succeeded" = true ]; then
      remaining=$(git -C "$worktree_path" diff --name-only --diff-filter=U || true)
      [ -z "$remaining" ] && { echo "[merge] LLM resolved"; return 0; }
    fi

    git -C "$worktree_path" merge --abort 2>/dev/null || true
    echo "[merge] could not resolve — aborted"
    return 1
  } >> "$log_file" 2>&1
}

# ── post-fix cycle + summary ─────────────────────────────────────────────────

post_fix_summary() {
  local pr_num="$1" triage_file="$2" responses_file="$3" log_file="$4"
  [ "$DRY_RUN" = true ] && return 0

  {
    local skip_ct auto_ct fixed_ct llm_ct total_ct resolved
    skip_ct="$(jq '.skip | length' < "$triage_file")"
    auto_ct="$(jq '.auto | length' < "$triage_file")"
    fixed_ct="$(jq '.already_likely_fixed | length' < "$triage_file")"
    llm_ct="$(jq '.needs_llm | length' < "$triage_file")"
    total_ct="$(jq '.all | length' < "$triage_file")"
    resolved=0
    [ -f "$responses_file" ] && resolved=$(jq '[.[] | select(.action == "fixed" or .action == "already_fixed")] | length' < "$responses_file" 2>/dev/null || echo "0")

    printf -v body '%s\n' \
      "🤖 **gh crfix** — Fix Summary" "" \
      "| Stage | Count |" "|-------|-------|" \
      "| Total threads | $total_ct |" \
      "| Skipped (deterministic) | $skip_ct |" \
      "| Already likely fixed | $fixed_ct |" \
      "| Auto/mechanical | $auto_ct |" \
      "| Sent to LLM | $llm_ct |" \
      "| Resolved | $resolved |"

    pr_comment "$pr_num" "$body"
    echo "[summary] posted"
  } >> "$log_file" 2>&1
}

post_fix_review_cycle() {
  local pr_num="$1" worktree_path="$2" fixed_count="$3" log_file="$4"
  { [ "$NO_POST_FIX" = true ] || [ "$DRY_RUN" = true ]; } && return 0

  {
    echo "[post-fix] waiting ${REVIEW_WAIT_SECS}s..."
    sleep "$REVIEW_WAIT_SECS"

    local new_threads new_count
    new_threads="$(get_unresolved_threads "$OWNER_REPO" "$pr_num")"
    new_count="$(echo "$new_threads" | jq 'length')"

    if [ "$new_count" -eq 0 ]; then
      echo "[post-fix] no new comments"
      pr_comment "$pr_num" "🤖 **gh crfix**: All $fixed_count comments addressed. No new issues after re-review."
      if ! merge_base_branch "$pr_num" "$worktree_path" "$log_file"; then
        pr_comment "$pr_num" "🤖 **gh crfix**: ⚠️ Could not merge base branch — conflicts require manual resolution."
      fi
      request_copilot_review "$pr_num"
      echo "[post-fix] done"
    else
      echo "[post-fix] $new_count new comment(s)"
      pr_comment "$pr_num" "🤖 **gh crfix**: Fixed $fixed_count comments, but $new_count new issue(s) raised. Run again to address."
    fi
  } >> "$log_file" 2>&1
}

run_pre_gate_phase() {
  local pr_num="$1" worktree_path="$2" triage_file="$3" hook="$4" validate_runner="$5" log_file="$6"
  local validation_file="$LOG_DIR/pr-$pr_num-validation.json"
  local gate_context="$LOG_DIR/pr-$pr_num-gate-context.json"

  run_autofix_hook "$worktree_path" "$hook" "$log_file"
  run_validation "$worktree_path" "$validate_runner" "$validation_file" "$log_file"
  build_gate_context "$triage_file" "$validation_file" "$gate_context"

  {
    echo "[score] $(cat "$gate_context")"
  } >> "$log_file" 2>&1
}

