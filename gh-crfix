# Get status of a PR: queued | running | done | failed
pr_status() {
  local pr_num="$1"
  if [ -f "$LOG_DIR/pr-${pr_num}.status" ]; then
    local s
    s="$(cat "$LOG_DIR/pr-${pr_num}.status")"
    if [ "$s" = "OK" ]; then echo "done"; else echo "failed"; fi
  elif [ -f "$LOG_DIR/pr-${pr_num}.started" ]; then
    echo "running"
  else
    echo "queued"
  fi
}

# Elapsed time formatted as M:SS
pr_elapsed() {
  local pr_num="$1"
  local start_file="$LOG_DIR/pr-${pr_num}.started"
  if [ ! -f "$start_file" ]; then echo "    "; return; fi
  local start now elapsed mins secs
  start="$(cat "$start_file")"
  now="$(date +%s)"
  elapsed=$((now - start))
  mins=$((elapsed / 60))
  secs=$((elapsed % 60))
  printf '%d:%02d' "$mins" "$secs"
}

# Get N-th PR number from ready list (0-indexed)
pr_at_index() {
  local idx="$1" i=0
  for pr in $TUI_READY_LIST; do
    if [ "$i" -eq "$idx" ]; then echo "$pr"; return; fi
    i=$((i + 1))
  done
}

progress_steps() {
  cat <<'EOF'
normalize_case
merge_base
resolve_conflicts
fetch_threads
filter_threads
autofix
validate
gate
fix
reply
cleanup
rereview
postfix
EOF
}

progress_label() {
  case "$1" in
    normalize_case) echo "normalizing case-colliding tracked paths" ;;
    merge_base) echo "fetching new base branch and merging base branch" ;;
    resolve_conflicts) echo "optionally resolving conflicts and pushing" ;;
    fetch_threads) echo "fetching review comments from GitHub" ;;
    filter_threads) echo "filtering unresolved comments" ;;
    autofix) echo "running deterministic autofix hook" ;;
    validate) echo "running deterministic validation/tests" ;;
    gate) echo "using gate model to decide if a larger model is needed" ;;
    fix) echo "using fix model to apply changes" ;;
    reply) echo "replying to and resolving review threads" ;;
    cleanup) echo "cleaning up thread-responses artifact" ;;
    rereview) echo "requesting Copilot re-review" ;;
    postfix) echo "waiting for re-review and re-merging base branch" ;;
    *) echo "$1" ;;
  esac
}

progress_file() {
  local pr_num="$1" step="$2"
  echo "$LOG_DIR/pr-${pr_num}.step.${step}"
}

trim_note() {
  printf '%s' "${1:-}" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

display_path() {
  local path="${1:-}"
  case "$path" in
    "$HOME"/*) printf '~%s' "${path#$HOME}" ;;
    *) printf '%s' "$path" ;;
  esac
}

progress_set() {
  local pr_num="$1" step="$2" status="$3" note="${4:-}"
  [ -n "$LOG_DIR" ] || return 0
  note="$(trim_note "$note")"
  printf '%s\t%s\n' "$status" "$note" > "$(progress_file "$pr_num" "$step")"
}

progress_get_status() {
  local pr_num="$1" step="$2" file
  file="$(progress_file "$pr_num" "$step")"
  if [ -f "$file" ]; then
    awk -F '\t' 'NR==1 { print $1 }' "$file"
  else
    echo "pending"
  fi
}

progress_get_note() {
  local pr_num="$1" step="$2" file
  file="$(progress_file "$pr_num" "$step")"
  if [ -f "$file" ]; then
    awk -F '\t' 'NR==1 { $1=""; sub(/^\t/, ""); print }' "$file"
  else
    echo ""
  fi
}

progress_init() {
  local pr_num="$1" step
  while IFS= read -r step; do
    [ -n "$step" ] || continue
    progress_set "$pr_num" "$step" "pending" ""
  done <<EOF
$(progress_steps)
EOF
}

progress_mark_remaining() {
  local pr_num="$1" target_status="$2" reason="$3" step current
  while IFS= read -r step; do
    [ -n "$step" ] || continue
    current="$(progress_get_status "$pr_num" "$step")"
    case "$current" in
      pending|running)
        progress_set "$pr_num" "$step" "$target_status" "$reason"
        ;;
    esac
  done <<EOF
$(progress_steps)
EOF
}

progress_marker() {
  case "$1" in
    done) echo "[x]" ;;
    running) echo "[>]" ;;
    skipped) echo "[-]" ;;
    failed) echo "[!]" ;;
    *) echo "[ ]" ;;
  esac
}

progress_color() {
  case "$1" in
    done) echo "$c_green" ;;
    running) echo "$c_yellow" ;;
    failed) echo "$c_red" ;;
    *) echo "$c_gray" ;;
  esac
}

progress_should_render() {
  local pr_num="$1" step="$2"
  local status note
  status="$(progress_get_status "$pr_num" "$step")"
  note="$(progress_get_note "$pr_num" "$step")"

  case "$step:$status:$note" in
    normalize_case:skipped:not\ needed) return 1 ;;
    resolve_conflicts:skipped:not\ needed) return 1 ;;
  esac

  return 0
}

progress_snapshot() {
  local pr_num="$1" step status note
  while IFS= read -r step; do
    [ -n "$step" ] || continue
    progress_should_render "$pr_num" "$step" || continue
    status="$(progress_get_status "$pr_num" "$step")"
    note="$(progress_get_note "$pr_num" "$step")"
    printf '%s\t%s\t%s\n' "$status" "$(progress_label "$step")" "$note"
  done <<EOF
$(progress_steps)
EOF
}

# ── TUI: terminal input ─────────────────────────────────────────────────────
# Open a dedicated fd (4) for the terminal to avoid stdin conflicts
tui_open_tty() {
  exec 4</dev/tty
  stty -echo -icanon min 0 time 0 </dev/tty 2>/dev/null || true
}
tui_close_tty() {
  stty echo icanon </dev/tty 2>/dev/null || true
  exec 4<&- 2>/dev/null || true
}

# Read one keypress (non-blocking, ~0.4s timeout via loop)
tui_read_key() {
  local key=""
  local status=0
  # Use the dedicated tty fd
  IFS= read -rsn1 -t 1 key <&4 2>/dev/null
  status=$?

  if [ "$status" -ne 0 ]; then
    # Timeout — no input
    echo ""
    return
  fi

  if [ -z "$key" ]; then
    echo "ENTER"
    return
  fi

  # ESC character (decimal 27)
  local esc_char
  esc_char="$(printf '\033')"

  if [ "$key" = "$esc_char" ]; then
    # Read rest of escape sequence — arrow keys send ESC [ A/B/C/D
    local c1="" c2="" c3=""
    IFS= read -rsn1 -t 1 c1 <&4 2>/dev/null || true
    IFS= read -rsn1 -t 1 c2 <&4 2>/dev/null || true
    if [ "${c1}${c2}" = "[3" ]; then
      IFS= read -rsn1 -t 1 c3 <&4 2>/dev/null || true
    fi
    case "${c1}${c2}${c3}" in
      '[A') echo "UP" ;;
      '[B') echo "DOWN" ;;
      '[C') echo "RIGHT" ;;
      '[D') echo "LEFT" ;;
      '[3~') echo "DELETE" ;;
      *)    echo "ESC" ;;
    esac
  elif [ "$key" = $'\177' ] || [ "$key" = $'\010' ]; then
    echo "BACKSPACE"
  elif [ "$key" = $'\t' ]; then
    echo "TAB"
  elif [ "$key" = "q" ] || [ "$key" = "Q" ]; then
    echo "QUIT"
  else
    echo "$key"
  fi
}

